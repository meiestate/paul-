<script>
  // Set current year
  document.getElementById('yr').textContent = new Date().getFullYear();

  // Storage Keys
  const PROPS_KEY = "mei_properties_v1"; // Store admin-approved listings
  const LEADS_KEY = "mei_leads_v1";      // Store leads submitted (buyer requests)
  const BROKERS_KEY = "mei_brokers_v1";  // Store broker names (for assignment)
  const WA_TEMPLATE_KEY = "mei_whatsapp_template_v1"; // WhatsApp message template

  // Helper: escape HTML to avoid XSS
  function escapeHtml(str) {
    return String(str||"").replace(/[&<>"']/g, s => ({
      "&": "&amp;","<": "&lt;",">": "&gt;",'"':"&quot;","'":"&#39;"
    }[s]));
  }
  // Toast with role=status for screen readers
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.display = 'block';
    clearTimeout(t._timer);
    t._timer = setTimeout(() => t.style.display = 'none', 2600);
  }

  // ================= Landing Interactions =================
  // Scroll buttons
  document.querySelectorAll('[data-action="scroll"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.querySelector(btn.getAttribute('data-target'));
      if(target) target.scrollIntoView({behavior: 'smooth'});
    });
  });

  // Lead Form submission (offline queue if needed)
  document.getElementById('leadForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(e.target);
    const lead = {
      name: data.get('name'),
      phone: data.get('phone'),
      leadType: data.get('leadType'),
      locality: data.get('locality'),
      budgetMin: data.get('budgetMin'),
      budgetMax: data.get('budgetMax'),
      notes: data.get('notes'),
      createdAt: new Date().toISOString(),
      status: "NEW"
    };
    // TODO: Replace with API POST /leads when backend is ready
    // Offline: store in localStorage queue
    let leads = JSON.parse(localStorage.getItem(LEADS_KEY) || "[]");
    leads.unshift({ id: "L"+Date.now(), ...lead });
    localStorage.setItem(LEADS_KEY, JSON.stringify(leads));
    showToast("Lead submitted ✅ We’ll connect you soon.");
    e.target.reset();
  });

  // Broker Form submission
  document.getElementById('brokerForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(e.target);
    const broker = {
      name: data.get('brokerName'),
      phone: data.get('phone'),
      area: data.get('area'),
      experience: data.get('exp'),
      company: data.get('company'),
      onboardedAt: new Date().toISOString(),
      verified: false
    };
    // Save broker name for assignments
    let brokers = JSON.parse(localStorage.getItem(BROKERS_KEY) || "[]");
    if(broker.name) brokers.push(broker.name.trim());
    brokers = Array.from(new Set(brokers)); // unique
    localStorage.setItem(BROKERS_KEY, JSON.stringify(brokers));
    showToast("Request received ✅ Verification team will call you.");
    e.target.reset();
  });

  // =======================================================

  // ==================== Buyer Portal ====================
  function getListings() {
    // Filter only approved properties
    let props = JSON.parse(localStorage.getItem(PROPS_KEY) || "[]");
    return props.filter(p => (p.status||"").toLowerCase() === "approved");
  }
  function getLeads() {
    return JSON.parse(localStorage.getItem(LEADS_KEY) || "[]");
  }
  // Render approved listings grid
  function renderListings() {
    const q = (document.getElementById('searchFilter').value || "").trim().toLowerCase();
    const typeF = document.getElementById('typeFilter').value.toLowerCase();
    let list = getListings();
    if(typeF) list = list.filter(p => (p.type||"").toLowerCase() === typeF);
    if(q) {
      list = list.filter(p => {
        const text = [p.title, p.city, p.locality, p.type, p.price].join(" ").toLowerCase();
        return text.includes(q);
      });
    }
    document.getElementById('count').textContent = list.length;
    const grid = document.getElementById('grid');
    grid.innerHTML = "";
    if(list.length === 0) {
      grid.innerHTML = `<div class="card"><div class="muted">No approved listings. Please check back later.</div></div>`;
      return;
    }
    list.forEach(p => {
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <div style="font-weight: 950; font-size: 16px;">${escapeHtml(p.title)}</div>
        <div class="mini">${escapeHtml(p.city)}, ${escapeHtml(p.locality)} • ${escapeHtml(p.type)}</div>
        <div class="price">${p.price? "₹"+Number(p.price).toLocaleString("en-IN") : "Price on request"}</div>
        <div class="mini" style="margin-top:4px;">ID: ${escapeHtml(p.id)}</div>
        <div class="actions" style="margin-top:10px;">
          <button class="btn small" data-action="openLeadModal" data-id="${escapeHtml(p.id)}" data-title="${escapeHtml(p.title)}">Request / Contact</button>
        </div>`;
      grid.appendChild(card);
    });
  }
  // Open lead modal for a listing
  function openLeadModal(id, title) {
    document.getElementById('leadListingTitle').textContent = title;
    document.getElementById('modalName').value = "";
    document.getElementById('modalPhone').value = "";
    document.getElementById('modalMsg').value = "";
    document.getElementById('leadToast').style.display = 'none';
    window._currentListingId = id; // for form submission
    document.getElementById('leadModal').style.display = 'block';
  }
  function closeLeadModal() {
    document.getElementById('leadModal').style.display = 'none';
  }
  function submitLead() {
    const name = document.getElementById('modalName').value.trim();
    const phone = document.getElementById('modalPhone').value.trim();
    const msg = document.getElementById('modalMsg').value.trim();
    if(!name || !phone) { alert("Name and Phone are required."); return; }
    const lead = {
      id: "L" + Date.now(),
      listingId: window._currentListingId,
      listingTitle: document.getElementById('leadListingTitle').textContent,
      buyerName: name,
      buyerPhone: phone,
      message: msg,
      status: "NEW",
      createdAt: new Date().toISOString()
    };
    let leads = JSON.parse(localStorage.getItem(LEADS_KEY) || "[]");
    leads.unshift(lead);
    localStorage.setItem(LEADS_KEY, JSON.stringify(leads));
    document.getElementById('leadToast').style.display = 'block';
    setTimeout(closeLeadModal, 900);
  }
  // Event delegation for listing buttons
  document.body.addEventListener('click', (e) => {
    if(e.target.dataset.action === 'openLeadModal') {
      openLeadModal(e.target.dataset.id, e.target.dataset.title);
    }
    if(e.target.dataset.action === 'refresh') {
      renderListings();
      showToast("🔄 Listings refreshed");
    }
  });
  // =======================================================

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    renderListings();
  });
</script>

</body>
</html>
```

**Key Implementation Notes:** 
- We merged the landing and buyer portal in one file, preserving `lang="ta"`. 
- A skip link (Technique G1)【12†L19-L27】 was added. Focus outlines and high-contrast colors ensure WCAG compliance【15†L33-L36】【19†L41-L44】. 
- All data rendering uses `escapeHtml` (no unsafe `innerHTML`) and event delegation (`data-action`) instead of inline `onclick`. 
- The approved listings grid and search/filter come from `mei_properties_v1`, the leads (buyer requests) go into `mei_leads_v1`. 
- Form inputs use `type=tel`, `inputmode`, `autocomplete` for improved UX (MDN recommendation). 
- An *API mode* is stubbed with comments, indicating where to replace with actual `fetch` calls. 
- Server-side musts (rate-limit endpoints, scan uploads, use CSP/HSTS, secure cookies, etc.) are noted in comments.

