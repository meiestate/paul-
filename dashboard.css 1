:root{
  --bg:#08111f;
  --bg2:#0c1628;
  --card:#101b31;
  --card2:rgba(255,255,255,.035);
  --line:rgba(255,255,255,.12);
  --line2:rgba(255,255,255,.08);
  --txt:#e8eefc;
  --mut:rgba(232,238,252,.82);
  --mut2:rgba(232,238,252,.64);
  --pill:rgba(255,255,255,.08);
  --radius:18px;

  --brand:#8caaff;
  --brand2:#67e8f9;
  --focus: rgba(140,170,255,.95);

  --okBorder: rgba(0,255,150,.30);
  --okBg: rgba(0,255,150,.12);

  --warnBorder: rgba(255,200,0,.30);
  --warnBg: rgba(255,200,0,.12);

  --dangerBorder: rgba(255,0,90,.34);
  --dangerBg: rgba(255,0,90,.14);

  --blueBorder: rgba(0,153,255,.28);
  --blueBg: rgba(0,153,255,.14);

  --shadow: 0 18px 60px rgba(0,0,0,.32);
}

*{box-sizing:border-box}
html{scroll-behavior:smooth}

body{
  margin:0;
  font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial;
  background:
    radial-gradient(circle at top right, rgba(103,232,249,.10), transparent 25%),
    radial-gradient(circle at top left, rgba(140,170,255,.08), transparent 25%),
    linear-gradient(180deg, var(--bg), var(--bg2));
  color:var(--txt);
}

.wrap{max-width:1380px;margin:0 auto;padding:18px}

.stickyTop{
  position:sticky;
  top:0;
  z-index:40;
  backdrop-filter: blur(10px);
  background:linear-gradient(180deg, rgba(8,17,31,.92), rgba(8,17,31,.76));
  border-bottom:1px solid rgba(255,255,255,.06);
  margin:-18px -18px 18px -18px;
  padding:18px;
}

.card{
  background:linear-gradient(180deg, rgba(16,27,49,.96), rgba(16,27,49,.88));
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:16px;
  box-shadow:var(--shadow);
}

.glass{
  background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.025));
  border:1px solid rgba(255,255,255,.09);
}

.top{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.h1{font-size:28px;font-weight:900;letter-spacing:.2px}
.h2{font-size:18px;font-weight:900;letter-spacing:.2px}
.muted{opacity:.88;color:var(--mut)}
.row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.spacer{flex:1}

.heroBadge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:7px 10px;
  border-radius:999px;
  border:1px solid rgba(140,170,255,.24);
  background:rgba(140,170,255,.10);
  font-size:12px;
  font-weight:800;
  letter-spacing:.2px;
}

a.link{
  color:var(--txt);
  text-decoration:none;
  padding:9px 12px;
  border:1px solid var(--line);
  border-radius:12px;
  background:rgba(255,255,255,.04);
  display:inline-flex;
  align-items:center;
  gap:8px;
  min-height:38px;
  font-weight:800;
}
a.link:hover{background:rgba(255,255,255,.07)}
a.link:active{transform:translateY(1px)}

button{
  padding:9px 12px;
  border-radius:12px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.07);
  color:var(--txt);
  cursor:pointer;
  font-weight:800;
  min-height:38px;
}
button:hover{background:rgba(255,255,255,.10)}
button:active{transform:translateY(1px)}
button[disabled]{opacity:.55; cursor:not-allowed}

.btnSmall{padding:6px 10px; min-height:32px; font-weight:800}
.iconBtn{
  padding:6px;
  min-height:32px;
  min-width:32px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
}
.primary{
  background:linear-gradient(135deg, rgba(140,170,255,.24), rgba(103,232,249,.14));
  border-color:rgba(140,170,255,.34);
}
.danger{border-color:var(--dangerBorder);background:var(--dangerBg)}
.danger:hover{background:rgba(255,0,90,.20)}
.ok{border-color:var(--okBorder);background:var(--okBg)}
.ok:hover{background:rgba(0,255,150,.18)}
.warn{border-color:var(--warnBorder);background:var(--warnBg)}
.warn:hover{background:rgba(255,200,0,.18)}
.info{border-color:var(--blueBorder);background:var(--blueBg)}
.info:hover{background:rgba(0,153,255,.20)}

a.link:focus-visible,
button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible,
[role="menuitem"]:focus-visible{
  outline:3px solid var(--focus);
  outline-offset:2px;
}

.statsGrid{
  display:grid;
  grid-template-columns:repeat(5,minmax(0,1fr));
  gap:12px;
  margin-top:14px;
}
@media (max-width:1150px){ .statsGrid{grid-template-columns:repeat(3,minmax(0,1fr));} }
@media (max-width:760px){ .statsGrid{grid-template-columns:repeat(2,minmax(0,1fr));} }
@media (max-width:520px){ .statsGrid{grid-template-columns:1fr;} }

.stat{
  border-radius:18px;
  padding:16px;
  border:1px solid rgba(255,255,255,.10);
  background:
    radial-gradient(circle at top right, rgba(140,170,255,.12), transparent 30%),
    rgba(255,255,255,.03);
  min-height:110px;
}
.stat .k{
  font-size:28px;
  font-weight:900;
  margin-top:6px;
}
.stat .s{
  font-size:12px;
  color:var(--mut2);
  margin-top:6px;
}

.grid2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:12px}
.grid3{display:grid;grid-template-columns:1.25fr .95fr .85fr;gap:12px;margin-top:12px}
@media (max-width:1100px){ .grid3{grid-template-columns:1fr} }
@media (max-width:900px){ .grid2{grid-template-columns:1fr} }

.tableWrap{
  overflow:auto;
  margin-top:10px;
  border-radius:14px;
  border:1px solid var(--line2)
}
table{width:100%;border-collapse:collapse}
th,td{padding:10px;vertical-align:top}
thead th{
  opacity:.92;
  text-align:left;
  border-bottom:1px solid var(--line);
  position:sticky;
  top:0;
  background:var(--card);
  z-index:2;
  font-size:13px;
}
tbody tr{border-top:1px solid rgba(255,255,255,.10)}

.pill{
  display:inline-block;
  padding:4px 10px;
  border-radius:999px;
  font-size:12px;
  background:var(--pill);
  border:1px solid var(--line);
  opacity:.98
}
.mini{font-size:12px;color:var(--mut2)}
.title{font-weight:900}
.nowrap{white-space:nowrap}

.toast{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:10px;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid var(--okBorder);
  background:var(--okBg);
}
.toast[hidden]{display:none}
.toast.danger{border-color:var(--dangerBorder);background:var(--dangerBg)}
.toast.warn{border-color:var(--warnBorder);background:var(--warnBg)}
.toast.info{border-color:var(--blueBorder);background:var(--blueBg)}
.toastAction{
  margin-left:auto;
  padding:7px 10px;
  border-radius:10px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.06);
  font-weight:900;
  cursor:pointer;
  min-height:32px;
}
.toastAction[hidden]{display:none}

.overdueRow{
  background:linear-gradient(90deg, rgba(255,0,90,.12), transparent 56%);
  outline:1px solid rgba(255,0,90,.20);
  outline-offset:-1px;
}
.overdueLabel{
  margin-top:6px;
  color:rgba(255,120,170,.98);
  font-weight:900;
  letter-spacing:.2px;
}

.modalBack{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.62);
  padding:20px;
  display:flex;
  align-items:flex-start;
  justify-content:center;
  overflow:auto;
  z-index:100;
}
.modalBack[hidden]{display:none}
.modalCard{
  width:min(720px, 100%);
  margin:5vh auto;
  background:var(--card);
  border:1px solid rgba(255,255,255,.16);
  border-radius:18px;
  padding:16px;
  box-shadow:0 12px 40px rgba(0,0,0,.55);
}

input, select, textarea{
  width:100%;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.18);
  background:#091222;
  color:var(--txt);
  outline:none;
  min-height:40px;
}
input::placeholder, textarea::placeholder{color:rgba(232,238,252,.65)}
textarea{resize:vertical; min-height:130px}

.filterBar{
  display:grid;
  grid-template-columns: 1.2fr .8fr .75fr .75fr .75fr .55fr;
  gap:10px;
  margin-top:12px;
}
@media (max-width:1250px){ .filterBar{grid-template-columns:1fr 1fr 1fr;} }
@media (max-width:820px){ .filterBar{grid-template-columns:1fr 1fr;} }
@media (max-width:560px){ .filterBar{grid-template-columns:1fr;} }

.quickFilters{
  margin-top:10px;
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  align-items:center;
}
.qfBtn{padding:7px 10px; min-height:32px; font-weight:900}
.qfBtn.active{background:rgba(140,170,255,.18); border-color:rgba(140,170,255,.32)}

.templateGrid{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:12px;
  margin-top:12px;
}
@media (max-width:900px){ .templateGrid{grid-template-columns:1fr;} }

.brokerGrid{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:12px;
  margin-top:12px;
}
@media (max-width:900px){ .brokerGrid{grid-template-columns:1fr;} }

.chip{
  display:inline-flex;
  gap:8px;
  align-items:center;
  padding:6px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.14);
  margin:4px 6px 0 0;
}
.chipBtn{
  padding:6px 10px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.14);
  background:rgba(255,255,255,.05);
  font-weight:900;
  cursor:pointer;
  min-height:32px;
}
.chipBtn:hover{background:rgba(255,255,255,.08)}

.menu{
  position:fixed;
  min-width:220px;
  max-width:300px;
  background:var(--card);
  border:1px solid rgba(255,255,255,.18);
  border-radius:14px;
  padding:6px;
  box-shadow:0 12px 40px rgba(0,0,0,.6);
  z-index:9999;
}
.menu[hidden]{display:none}
.menuTitle{
  padding:8px 10px;
  font-size:12px;
  color:var(--mut2);
  letter-spacing:.2px;
}
.menuItem{
  width:100%;
  display:flex;
  align-items:center;
  gap:10px;
  padding:9px 10px;
  border-radius:12px;
  border:1px solid transparent;
  background:transparent;
  color:var(--txt);
  cursor:pointer;
  text-align:left;
  font-weight:900;
  min-height:36px;
}
.menuItem:hover{background:rgba(255,255,255,.07)}
.menuItem.danger:hover{background:rgba(255,0,90,.18)}
.menuItem .sub{margin-left:auto; font-size:12px; color:var(--mut2); font-weight:800}

.srOnly{
  position:absolute;
  width:1px;
  height:1px;
  padding:0;
  margin:-1px;
  overflow:hidden;
  clip:rect(0,0,0,0);
  border:0;
  white-space:nowrap;
}

.userBox{
  display:flex;
  align-items:center;
  gap:10px;
  padding:8px 10px;
  border:1px solid var(--line);
  border-radius:14px;
  background:rgba(255,255,255,.04);
}
#currentUserText{
  font-size:13px;
  color:var(--mut);
  font-weight:700;
  max-width:260px;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.panelList{
  display:grid;
  gap:10px;
  margin-top:10px;
}

.activityItem, .summaryItem{
  padding:12px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.03);
}

.summaryMetric{
  font-size:20px;
  font-weight:900;
  margin-top:4px;
}

.backupBox{
  display:grid;
  grid-template-columns:1fr auto auto auto;
  gap:10px;
  margin-top:12px;
  align-items:center;
}
@media (max-width:900px){
  .backupBox{grid-template-columns:1fr 1fr}
}
@media (max-width:560px){
  .backupBox{grid-template-columns:1fr}
}

.paginationBar{
  display:flex;
  flex-wrap:wrap;
  justify-content:space-between;
  gap:10px;
  margin-top:12px;
  align-items:center;
}

.kbd{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:22px;
  height:22px;
  padding:0 6px;
  border-radius:7px;
  border:1px solid rgba(255,255,255,.14);
  background:rgba(255,255,255,.05);
  font-size:12px;
  font-weight:900;
}

.empty{
  padding:20px;
  border-radius:14px;
  border:1px dashed rgba(255,255,255,.14);
  background:rgba(255,255,255,.02);
  color:var(--mut2);
  text-align:center;
}

.softHr{
  height:1px;
  background:linear-gradient(90deg, transparent, rgba(255,255,255,.12), transparent);
  margin:12px 0;
  border:0;
}

.previewBox{
  background:var(--card2);
  box-shadow:none;
}
.waPreview{
  white-space:pre-wrap;
  margin-top:10px;
  line-height:1.45;
}

.leadsTable{min-width:1540px}
.pageSizeSelect{width:auto;min-width:110px}
.modalForm{display:grid; gap:10px; margin-top:12px;}

