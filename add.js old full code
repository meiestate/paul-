/* ---------------- PROPERTIES ---------------- */

function getAllProperties() {
  return getData(MEI_KEYS.properties, []);
}

function saveAllProperties(properties) {
  return setData(MEI_KEYS.properties, properties);
}

function getApprovedProperties() {
  return getAllProperties().filter(item => item.status === "approved");
}

function getPendingProperties() {
  return getAllProperties().filter(item => item.status === "pending");
}

function getRejectedProperties() {
  return getAllProperties().filter(item => item.status === "rejected");
}

function getPropertyById(propertyId) {
  return getAllProperties().find(item => item.id === propertyId) || null;
}

function addProperty(data) {
  const properties = getAllProperties();

  const newProperty = {
    id: makeId("PROP"),
    title: sanitizeText(data.title),
    price: Number(data.price || 0),
    city: sanitizeText(data.city),
    area: sanitizeText(data.area),
    type: sanitizeText(data.type),
    bhk: sanitizeText(data.bhk),
    sqft: Number(data.sqft || 0),
    description: sanitizeText(data.description),
    image: sanitizeText(data.image),
    gallery: Array.isArray(data.gallery) && data.gallery.length
      ? data.gallery.map(item => sanitizeText(item)).filter(Boolean)
      : [sanitizeText(data.image)].filter(Boolean),
    sellerName: sanitizeText(data.sellerName),
    sellerPhone: normalizePhone(data.sellerPhone),
    brokerId: sanitizeText(data.brokerId),
    brokerName: sanitizeText(data.brokerName),
    status: "pending",
    createdAt: new Date().toISOString(),
    approvedAt: "",
    approvedBy: "",
    featured: false
  };

  properties.unshift(newProperty);
  saveAllProperties(properties);
  return newProperty;
}

function updatePropertyStatus(propertyId, newStatus, approvedBy = "admin") {
  const properties = getAllProperties();
  const updated = properties.map(item => {
    if (item.id === propertyId) {
      return {
        ...item,
        status: newStatus,
        approvedAt: newStatus === "approved" ? new Date().toISOString() : item.approvedAt,
        approvedBy: newStatus === "approved" ? approvedBy : item.approvedBy
      };
    }
    return item;
  });
  saveAllProperties(updated);
}

function approveProperty(propertyId, approvedBy = "admin") {
  updatePropertyStatus(propertyId, "approved", approvedBy);
}

function rejectProperty(propertyId) {
  updatePropertyStatus(propertyId, "rejected");
}

function archiveProperty(propertyId) {
  updatePropertyStatus(propertyId, "archived");
}

function deleteProperty(propertyId) {
  const properties = getAllProperties().filter(item => item.id !== propertyId);
  saveAllProperties(properties);
}

/* ---------------- LEADS ---------------- */

function getAllLeads() {
  return getData(MEI_KEYS.leads, []);
}

function saveAllLeads(leads) {
  return setData(MEI_KEYS.leads, leads);
}

function getLeadById(leadId) {
  return getAllLeads().find(item => item.id === leadId) || null;
}

function addLead(data) {
  const leads = getAllLeads();

  const newLead = {
    id: makeId("LEAD"),
    propertyId: sanitizeText(data.propertyId),
    propertyTitle: sanitizeText(data.propertyTitle),
    buyerName: sanitizeText(data.buyerName),
    buyerPhone: normalizePhone(data.buyerPhone),
    buyerCity: sanitizeText(data.buyerCity),
    message: sanitizeText(data.message),
    source: sanitizeText(data.source || "website"),
    status: sanitizeText(data.status || "new"),
    assignedBrokerId: sanitizeText(data.assignedBrokerId),
    assignedBrokerName: sanitizeText(data.assignedBrokerName),
    followUpDate: sanitizeText(data.followUpDate),
    notes: sanitizeText(data.notes),
    createdAt: new Date().toISOString()
  };

  leads.unshift(newLead);
  saveAllLeads(leads);
  return newLead;
}

function updateLeadStatus(leadId, newStatus) {
  const leads = getAllLeads();
  const updated = leads.map(item =>
    item.id === leadId ? { ...item, status: newStatus } : item
  );
  saveAllLeads(updated);
}

function updateLeadFollowUp(leadId, followUpDate) {
  const leads = getAllLeads();
  const updated = leads.map(item =>
    item.id === leadId ? { ...item, followUpDate: followUpDate } : item
  );
  saveAllLeads(updated);
}

function updateLeadNotes(leadId, notes) {
  const leads = getAllLeads();
  const updated = leads.map(item =>
    item.id === leadId ? { ...item, notes: sanitizeText(notes) } : item
  );
  saveAllLeads(updated);
}

function deleteLead(leadId) {
  const leads = getAllLeads().filter(item => item.id !== leadId);
  saveAllLeads(leads);
}

