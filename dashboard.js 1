  function trapFocusInModal(e){
    if($("leadModalBack").hidden) return;

    if(e.key === "Escape"){
      e.preventDefault();
      closeLeadModal();
      return;
    }
    if(e.key !== "Tab") return;

    const modal = $("leadModalBack").querySelector(".modalCard");
    const focusables = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const list = Array.from(focusables).filter(x => !x.disabled && x.offsetParent !== null);

    if(!list.length) return;

    const first = list[0];
    const last = list[list.length - 1];

    if(e.shiftKey && document.activeElement === first){
      e.preventDefault();
      last.focus();
    }else if(!e.shiftKey && document.activeElement === last){
      e.preventDefault();
      first.focus();
    }
  }

  // ====== Filters ======
  function leadMatchesSearch(lead, q){
    if(!q) return true;
    const hay = [
      lead.listingTitle, lead.listingId,
      lead.buyerName, lead.buyerPhone,
      lead.message, lead.notes,
      lead.assignedTo
    ].join(" ").toLowerCase();
    return hay.includes(q);
  }

  function applyLeadSort(list){
    const mode = ($("sortFilter").value || "NEWEST").toUpperCase();
    const arr = list.slice();

    const dateVal = (v) => {
      const d = new Date(v || 0);
      return Number.isNaN(d.getTime()) ? 0 : d.getTime();
    };

    const str = (v) => String(v || "").toLowerCase();

    if(mode === "NEWEST") arr.sort((a,b)=> dateVal(b.createdAt) - dateVal(a.createdAt));
    else if(mode === "OLDEST") arr.sort((a,b)=> dateVal(a.createdAt) - dateVal(b.createdAt));
    else if(mode === "FOLLOWUP_ASC") arr.sort((a,b)=> str(a.followUp).localeCompare(str(b.followUp)));
    else if(mode === "FOLLOWUP_DESC") arr.sort((a,b)=> str(b.followUp).localeCompare(str(a.followUp)));
    else if(mode === "BUYER_AZ") arr.sort((a,b)=> str(a.buyerName).localeCompare(str(b.buyerName)));
    else if(mode === "LISTING_AZ") arr.sort((a,b)=> str(a.listingTitle).localeCompare(str(b.listingTitle)));

    return arr;
  }

  function applyLeadFilters(leadsRaw){
    const q = ($("leadSearch").value || "").trim().toLowerCase();
    const brokerF = ($("brokerFilter").value || "ALL");
    const statusF = ($("statusFilter").value || "ALL").toUpperCase();
    const odF = ($("overdueFilter").value || "ALL").toUpperCase();

    let out = leadsRaw
      .filter(l => leadMatchesSearch(l, q))
      .filter(l => {
        if(brokerF === "ALL") return true;
        if(brokerF === "__UNASSIGNED__") return !(l.assignedTo || "").trim();
        return (l.assignedTo || "") === brokerF;
      })
      .filter(l => statusF === "ALL" ? true : (l.status || "NEW").toUpperCase() === statusF)
      .filter(l => {
        if(odF === "ALL") return true;
        const od = isOverdue(l);
        if(odF === "OVERDUE") return od;
        if(odF === "NOT_OVERDUE") return !od;
        return true;
      })
      .filter(l => {
        if(QUICK.unassignedOnly && (l.assignedTo || "").trim()) return false;
        if(QUICK.overdueOnly && !isOverdue(l)) return false;
        if(QUICK.dueTodayOnly && !isDueToday(l)) return false;
        return true;
      });

    out = applyLeadSort(out);
    return out;
  }

