  // ====== CSV ======
  function csvEscape(v){
    const s = String(v ?? "");
    return `"${s.replace(/"/g,'""')}"`;
  }

  function exportFilteredLeadsCSV(){
    const rows = CURRENT_FILTERED_LEADS || [];
    if(rows.length === 0){ alert("No filtered leads to export."); return; }

    const header = ["CreatedAt","ListingTitle","ListingId","BuyerName","BuyerPhone","AssignedTo","Status","FollowUp","Notes","Message"];
    const lines = [];
    lines.push(header.map(csvEscape).join(","));

    rows.forEach(l => {
      const line = [
        fmtDate(l.createdAt),
        l.listingTitle || "",
        l.listingId || "",
        l.buyerName || "",
        l.buyerPhone || "",
        l.assignedTo || "",
        (l.status || "NEW"),
        l.followUp || "",
        l.notes || "",
        l.message || ""
      ];
      lines.push(line.map(csvEscape).join(","));
    });

    const csv = lines.join("\n");
    const blob = new Blob([csv], {type:"text/csv;charset=utf-8;"});
    const url = URL.createObjectURL(blob);

    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    const fname = `MEI_Leads_${yyyy}-${mm}-${dd}.csv`;

    const a = document.createElement("a");
    a.href = url;
    a.download = fname;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);

    addActivity(`CSV exported: ${fname}`, "info");
    toast(`⬇ Exported CSV: ${fname}`);
  }

