  function setLeadAssigned(id, broker){
    const leads = getLeads();
    const idx = leads.findIndex(l => l.id === id);
    if(idx === -1) return;
    const prev = leads[idx].assignedTo || "";
    leads[idx].assignedTo = String(broker || "").trim();
    leads[idx].updatedAt = new Date().toISOString();
    saveLeads(leads);
    addActivity(`Lead assignment changed: ${leads[idx].buyerName || id} → ${leads[idx].assignedTo || "Unassigned"}`, "info");
    toast(prev !== broker ? "👤 Assigned updated" : "No change");
    refreshLeads();
    renderBrokerSummary();
    refreshStats();
  }

  function setLeadStatus(id, status){
    const leads = getLeads();
    const idx = leads.findIndex(x => x.id === id);
    if(idx === -1) return;

    const prev = Object.assign({}, leads[idx]);
    leads[idx].status = status;
    leads[idx].updatedAt = new Date().toISOString();

    if(String(status).toUpperCase() === "CONTACTED"){
      leads[idx].lastContactedAt = new Date().toISOString();
      if(!leads[idx].followUp){
        const d = new Date(); d.setDate(d.getDate()+1);
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth()+1).padStart(2,"0");
        const dd = String(d.getDate()).padStart(2,"0");
        leads[idx].followUp = `${yyyy}-${mm}-${dd}`;
      }
    }

    saveLeads(leads);
    addActivity(`Lead status changed: ${leads[idx].buyerName || id} → ${String(status).toUpperCase()}`, "ok");

    const isUndoWorthy = ["CLOSED","ARCHIVED"].includes(String(status).toUpperCase());
    if(isUndoWorthy){
      toast(`✅ Lead marked ${String(status).toUpperCase()}`, {
        actionText: "Undo",
        actionFn: () => {
          const ls = getLeads();
          const i2 = ls.findIndex(x => x.id === id);
          if(i2 === -1) return;
          ls[i2] = normalizeLead(prev);
          saveLeads(ls);
          addActivity(`Undo status change for ${prev.buyerName || id}`, "warn");
          toast("↩ Undone", { type:"warn" });
          refreshLeads();
          refreshStats();
          renderPipelineSummary();
          renderBrokerSummary();
        },
        timeout: 4500
      });
    }else{
      toast("✅ Lead updated");
    }

    refreshLeads();
    refreshStats();
    renderPipelineSummary();
    renderBrokerSummary();
  }

