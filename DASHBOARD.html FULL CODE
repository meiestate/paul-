<script>
  // ===== Role / Auth Compatibility =====
  try{
    if (typeof requireRole === "function") {
      requireRole(["admin"]);
    }
  }catch(e){}

  const currentUser = (typeof getCurrentUser === "function")
    ? getCurrentUser()
    : null;

  // ====== Storage Keys ======
  const PROPS_KEY = "mei_properties_v1";
  const LEADS_KEY = "mei_leads_v1";
  const WA_TEMPLATE_KEY = "mei_whatsapp_template_v1";
  const BROKERS_KEY = "mei_brokers_v1";
  const ACTIVITY_KEY = "mei_activity_v1";
  const CURRENT_USER_KEY = "mei_current_user_v1";

  // ====== State ======
  let MODAL_LEAD_ID = null;
  let CURRENT_FILTERED_LEADS = [];
  let LAST_FOCUSED_BEFORE_MODAL = null;
  let LEAD_SEARCH_TIMER = null;

  const QUICK = {
    overdueOnly: false,
    dueTodayOnly: false,
    unassignedOnly: false,
  };

  const MENU = {
    open: false,
    leadId: null,
    anchorEl: null,
  };

  const PAGINATION = {
    page: 1,
    pageSize: 20,
    totalPages: 1
  };

  const $ = (id)=>document.getElementById(id);

  // ====== Tiny DOM helpers ======
  function el(tag, attrs = {}, children = []){
    const node = document.createElement(tag);
    for (const [k,v] of Object.entries(attrs || {})){
      if(k === "class") node.className = v;
      else if(k === "text") node.textContent = v;
      else if(k === "html") node.innerHTML = v;
      else if(k === "style") node.style.cssText = v;
      else if(k.startsWith("data-")) node.setAttribute(k, v);
      else if(v === true) node.setAttribute(k, "");
      else if(v !== false && v != null) node.setAttribute(k, String(v));
    }
    (children || []).forEach(ch => {
      if(ch == null) return;
      if(typeof ch === "string") node.appendChild(document.createTextNode(ch));
      else node.appendChild(ch);
    });
    return node;
  }

  function uid(){
    try{
      if(window.crypto && crypto.randomUUID) return crypto.randomUUID();
    }catch(e){}
    return "id_" + Math.random().toString(16).slice(2) + "_" + Date.now().toString(16);
  }

  // ====== Toast ======
  let TOAST_TIMER = null;
  let TOAST_ACTION_FN = null;

  function toast(msg = "✅ Updated", opts = {}){
    const { type = "ok", actionText = "", actionFn = null, timeout = 1800 } = opts;

    const t = $("toast");
    const m = $("toastMsg");
    const a = $("toastAction");

    t.classList.remove("danger","warn","info");
    if(type === "danger") t.classList.add("danger");
    if(type === "warn") t.classList.add("warn");
    if(type === "info") t.classList.add("info");

    m.textContent = msg;

    TOAST_ACTION_FN = (typeof actionFn === "function") ? actionFn : null;
    if(actionText && TOAST_ACTION_FN){
      a.textContent = actionText;
      a.hidden = false;
    }else{
      a.hidden = true;
    }

    t.hidden = false;

    if(TOAST_TIMER) clearTimeout(TOAST_TIMER);
    TOAST_TIMER = setTimeout(()=>{
      t.hidden = true;
      a.hidden = true;
      TOAST_ACTION_FN = null;
    }, timeout);
  }

  function onToastAction(){
    if(typeof TOAST_ACTION_FN === "function"){
      const fn = TOAST_ACTION_FN;
      $("toast").hidden = true;
      $("toastAction").hidden = true;
      TOAST_ACTION_FN = null;
      try{ fn(); }catch(e){}
    }
  }

  // ====== Date helpers ======
  function fmtDate(iso){
    try {
      const d = new Date(iso);
      if(Number.isNaN(d.getTime())) return String(iso || "");
      return d.toLocaleString();
    } catch(e){
      return String(iso || "");
    }
  }

  function todayYMD(){
    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function todayDateObj(){
    const d = new Date();
    d.setHours(0,0,0,0);
    return d;
  }

  function isOverdue(lead){
    const status = (lead.status || "").toUpperCase();
    if(["CLOSED","ARCHIVED"].includes(status)) return false;
    if(!lead.followUp) return false;
    return String(lead.followUp) < todayYMD();
  }

  function isDueToday(lead){
    const status = (lead.status || "").toUpperCase();
    if(["CLOSED","ARCHIVED"].includes(status)) return false;
    if(!lead.followUp) return false;
    return String(lead.followUp) === todayYMD();
  }

  function isContactedToday(lead){
    if(!lead.lastContactedAt) return false;
    const d = new Date(lead.lastContactedAt);
    if(Number.isNaN(d.getTime())) return false;
    const today = todayDateObj();
    d.setHours(0,0,0,0);
    return d.getTime() === today.getTime();
  }

  // ====== Normalizers ======
  function normalizeProp(p){
    const out = Object.assign({}, p || {});
    if(!out.id) out.id = uid();
    if(!out.status) out.status = "pending";
    if(!out.title && out.name) out.title = out.name;
    if(out.createdAt == null) out.createdAt = new Date().toISOString();
    return out;
  }

  function normalizeLead(lead){
    const out = Object.assign({}, lead || {});
    if(!out.id) out.id = uid();
    if(!out.createdAt) out.createdAt = new Date().toISOString();
    if(out.notes == null) out.notes = "";
    if(out.message == null) out.message = "";
    if(out.followUp == null) out.followUp = "";
    if(out.lastContactedAt == null) out.lastContactedAt = "";
    if(out.updatedAt == null) out.updatedAt = "";
    if(out.status == null) out.status = "NEW";
    if(out.assignedTo == null) out.assignedTo = "";
    if(out.buyerName == null) out.buyerName = "";
    if(out.buyerPhone == null) out.buyerPhone = "";
    if(out.listingTitle == null) out.listingTitle = "";
    if(out.listingId == null) out.listingId = "";
    return out;
  }

  // ====== Data access ======
  function safeReadJSON(key, fallback){
    try{
      const raw = localStorage.getItem(key);
      if(!raw) return fallback;
      const parsed = JSON.parse(raw);
      return parsed ?? fallback;
    }catch(e){
      return fallback;
    }
  }

  function safeWriteJSON(key, value){
    localStorage.setItem(key, JSON.stringify(value));
  }

  function getProps(){ return safeReadJSON(PROPS_KEY, []).map(normalizeProp); }
  function saveProps(props){ safeWriteJSON(PROPS_KEY, (props || []).map(normalizeProp)); }

  function getLeads(){ return safeReadJSON(LEADS_KEY, []).map(normalizeLead); }
  function saveLeads(leads){ safeWriteJSON(LEADS_KEY, (leads || []).map(normalizeLead)); }

  function getBrokers(){ return safeReadJSON(BROKERS_KEY, []); }
  function saveBrokers(list){
    const cleaned = Array.from(new Set((list || [])
      .map(x => String(x||"").trim())
      .filter(Boolean)
    ));
    safeWriteJSON(BROKERS_KEY, cleaned);
  }

  function getActivities(){
    const arr = safeReadJSON(ACTIVITY_KEY, []);
    return Array.isArray(arr) ? arr : [];
  }

  function saveActivities(list){
    const safe = Array.isArray(list) ? list.slice(0, 80) : [];
    safeWriteJSON(ACTIVITY_KEY, safe);
  }

  function addActivity(text, type = "info"){
    const items = getActivities();
    items.unshift({
      id: uid(),
      text: String(text || ""),
      type: String(type || "info"),
      at: new Date().toISOString()
    });
    saveActivities(items.slice(0, 40));
    renderActivityFeed();
  }

  // ====== User display ======
  function renderCurrentUser(){
    if(currentUser && $("currentUserText")){
      const n = currentUser.name || "Admin";
      const r = currentUser.role || "admin";
      $("currentUserText").textContent = `${n} • ${r}`;
      return;
    }
    $("currentUserText").textContent = "Admin • local";
  }

  function logoutUserLocal(){
    try{
      if(typeof logoutUser === "function"){
        logoutUser();
        return;
      }
    }catch(e){}
    localStorage.removeItem(CURRENT_USER_KEY);
    location.href = "login.html";
  }

  // ====== Broker master ======
  function renderBrokerChips(){
    const brokers = getBrokers();
    const wrap = $("brokerChips");
    wrap.innerHTML = "";

    if(brokers.length === 0){
      wrap.appendChild(el("div", { class:"mini", style:"opacity:.85", text:"No brokers yet. Add one." }));
      return;
    }

    brokers.forEach(b => {
      const name = String(b);
      const chip = el("span", { class:"chip" }, [
        el("span", { style:"font-weight:900", text:name }),
        el("button", {
          type:"button",
          class:"danger iconBtn",
          "aria-label":`Remove broker ${name}`
        }, [ "✕" ])
      ]);

      chip.querySelector("button").addEventListener("click", () => deleteBroker(name));
      wrap.appendChild(chip);
    });
  }

  function addBroker(){
    const name = ($("brokerName").value || "").trim();
    if(!name){ alert("Enter broker name"); return; }
    const brokers = getBrokers();
    if(brokers.includes(name)){
      toast("Broker already exists", { type:"warn" });
      return;
    }
    brokers.push(name);
    saveBrokers(brokers);
    $("brokerName").value = "";
    addActivity(`Broker added: ${name}`, "ok");
    toast("✅ Broker added");
    syncBrokerDropdowns();
    refreshLeads();
    renderBrokerSummary();
    refreshStats();
  }

  function deleteBroker(name){
    if(!confirm(`Delete broker "${name}" from list?`)) return;
    const brokers = getBrokers().filter(b => b !== name);
    saveBrokers(brokers);
    addActivity(`Broker removed: ${name}`, "warn");
    toast("🧹 Broker removed", { type:"warn" });
    syncBrokerDropdowns();
    refreshLeads();
    renderBrokerSummary();
    refreshStats();
  }

  function seedBrokers(){
    const brokers = getBrokers();
    if(brokers.length) { toast("Already has brokers"); return; }
    saveBrokers(["Raj","Karthik","Priya","Sanjay"]);
    addActivity("Demo brokers seeded", "info");
    toast("✨ Demo brokers added");
    syncBrokerDropdowns();
    refreshLeads();
    renderBrokerSummary();
    refreshStats();
  }

  function syncBrokerDropdowns(){
    renderBrokerChips();

    const bf = $("brokerFilter");
    const current = bf.value || "ALL";
    bf.innerHTML = "";
    bf.appendChild(el("option", { value:"ALL", text:"All Brokers" }));
    bf.appendChild(el("option", { value:"__UNASSIGNED__", text:"Unassigned" }));
    getBrokers().forEach(b => bf.appendChild(el("option", { value:b, text:b })));
    const has = Array.from(bf.options).some(o => o.value === current);
    bf.value = has ? current : "ALL";

    const md = $("mAssigned");
    const curM = md.value || "";
    md.innerHTML = "";
    md.appendChild(el("option", { value:"", text:"Unassigned" }));
    getBrokers().forEach(b => md.appendChild(el("option", { value:b, text:b })));
    md.value = Array.from(md.options).some(o => o.value === curM) ? curM : "";
  }

  function renderBrokerSummary(){
    const body = $("brokerSummaryBody");
    const brokers = getBrokers();
    const leads = getLeads();
    body.innerHTML = "";

    if(!brokers.length){
      body.appendChild(el("tr", {}, [
        el("td", { colspan:"5", style:"padding:14px;opacity:.80;", text:"No brokers added yet." })
      ]));
      return;
    }

    brokers.forEach(name => {
      const own = leads.filter(l => (l.assignedTo || "").trim() === name);
      const contacted = own.filter(l => (l.status || "").toUpperCase() === "CONTACTED").length;
      const closed = own.filter(l => (l.status || "").toUpperCase() === "CLOSED").length;
      const overdue = own.filter(isOverdue).length;

      body.appendChild(el("tr", {}, [
        el("td", { text:name }),
        el("td", { text:String(own.length) }),
        el("td", { text:String(contacted) }),
        el("td", { text:String(closed) }),
        el("td", { text:String(overdue) }),
      ]));
    });
  }

  // ====== WhatsApp Template ======
  function defaultWATemplate(){
    return `Hello {buyer},

Thanks for your interest in "{listing}".

This is MEI Realty. Please share your preferred time to discuss today.

- MEI`;
  }

  function getWATemplate(){
    return localStorage.getItem(WA_TEMPLATE_KEY) || defaultWATemplate();
  }

  function saveWATemplateFn(){
    const val = ($("waTemplate").value || "").trim();
    if(!val){ alert("Template cannot be empty"); return; }
    localStorage.setItem(WA_TEMPLATE_KEY, val);
    addActivity("WhatsApp template saved", "ok");
    toast("💾 WhatsApp template saved");
    updatePreview();
  }

  function resetWATemplate(){
    localStorage.setItem(WA_TEMPLATE_KEY, defaultWATemplate());
    $("waTemplate").value = getWATemplate();
    addActivity("WhatsApp template reset", "warn");
    toast("↩ Template reset to default", { type:"warn" });
    updatePreview();
  }

  function applyTemplate(tpl, lead){
    const dateStr = new Date().toLocaleDateString();
    return String(tpl || "")
      .replaceAll("{buyer}", lead.buyerName || "")
      .replaceAll("{listing}", lead.listingTitle || "property")
      .replaceAll("{phone}", lead.buyerPhone || "")
      .replaceAll("{date}", dateStr);
  }

  function updatePreview(){
    const tpl = ($("waTemplate").value || "").trim() || defaultWATemplate();
    const sample = { buyerName:"Arun", listingTitle:"2BHK Whitefield", buyerPhone:"9876543210" };
    $("waPreview").textContent = applyTemplate(tpl, sample);
  }

  function insertAtCursor(textarea, insertText){
    textarea.focus();
    const start = textarea.selectionStart ?? textarea.value.length;
    const end = textarea.selectionEnd ?? textarea.value.length;
    const before = textarea.value.slice(0, start);
    const after = textarea.value.slice(end);
    textarea.value = before + insertText + after;
    const newPos = start + insertText.length;
    textarea.setSelectionRange(newPos, newPos);
  }

  // ====== Clipboard ======
  async function copyToClipboard(text){
    const t = String(text ?? "");
    if(!t.trim()){ alert("Nothing to copy"); return false; }
    try{
      if(navigator.clipboard && window.isSecureContext){
        await navigator.clipboard.writeText(t);
        return true;
      }
    }catch(e){}
    try{
      const ta = document.createElement("textarea");
      ta.value = t;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      ta.style.top = "-9999px";
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      const ok = document.execCommand("copy");
      ta.remove();
      return ok;
    }catch(e){
      return false;
    }
  }

  async function copyPreview(){
    const txt = $("waPreview").textContent || "";
    const ok = await copyToClipboard(txt);
    if(ok) toast("📋 Preview copied");
    else alert("Copy failed.");
  }

  // ====== WhatsApp + Copy ======
  function cleanPhoneForWA(phone){
    const clean = String(phone || "").replace(/[^\d]/g,'');
    if(clean.length === 10) return "91" + clean;
    return clean;
  }

  function buildLeadMessage(lead){
    const tpl = getWATemplate();
    return applyTemplate(tpl, lead);
  }

  function safeOpenNewTab(url){
    const w = window.open(url, "_blank", "noopener,noreferrer");
    if(w) w.opener = null;
    return w;
  }

  function openWhatsAppForLead(leadId){
    const lead = getLeads().find(l => l.id === leadId);
    if(!lead) return;
    if(!lead.buyerPhone){ alert("No phone number"); return; }

    const finalPhone = cleanPhoneForWA(lead.buyerPhone);
    const message = buildLeadMessage(lead);
    const url = `https://wa.me/${finalPhone}?text=${encodeURIComponent(message)}`;

    safeOpenNewTab(url);
    autoLogCommunication(leadId, "WhatsApp opened");
    addActivity(`WhatsApp opened for ${lead.buyerName || "lead"}`, "info");
    toast("💬 WhatsApp opened + Logged");
    refreshLeads();
  }

  async function copyLeadMessageById(leadId){
    const lead = getLeads().find(l => l.id === leadId);
    if(!lead) return;

    const message = buildLeadMessage(lead);
    const ok = await copyToClipboard(message);

    if(ok){
      autoLogCommunication(leadId, "Message copied");
      addActivity(`Message copied for ${lead.buyerName || "lead"}`, "info");
      toast("📋 Message copied + Logged");
      refreshLeads();
    }else{
      alert("Copy failed.");
    }
  }

  // ====== Auto Log ======
  function autoLogCommunication(leadId, type){
    const leads = getLeads();
    const idx = leads.findIndex(l => l.id === leadId);
    if(idx === -1) return;

    const now = new Date();
    const logLine = `[${now.toLocaleString()}] ${type}`;

    const existing = (leads[idx].notes || "").trim();
    leads[idx].notes = existing ? (existing + "\n" + logLine) : logLine;

    leads[idx].status = "CONTACTED";
    leads[idx].lastContactedAt = now.toISOString();
    leads[idx].updatedAt = now.toISOString();

    if(!leads[idx].followUp){
      const d = new Date();
      d.setDate(d.getDate()+1);
      const yyyy = d.getFullYear();
      const mm = String(d.getMonth()+1).padStart(2,"0");
      const dd = String(d.getDate()).padStart(2,"0");
      leads[idx].followUp = `${yyyy}-${mm}-${dd}`;
    }

    saveLeads(leads);
  }

