  function onMenuKeydown(e){
    if($("overflowMenu").hidden) return;

    if(e.key === "Escape"){
      e.preventDefault();
      closeMenu();
      return;
    }

    const items = Array.from($("overflowMenu").querySelectorAll('[role="menuitem"]'));
    if(!items.length) return;

    const cur = document.activeElement;
    const idx = items.indexOf(cur);

    if(e.key === "ArrowDown"){
      e.preventDefault();
      const next = items[(idx + 1) % items.length] || items[0];
      next.focus();
    }else if(e.key === "ArrowUp"){
      e.preventDefault();
      const prev = items[(idx - 1 + items.length) % items.length] || items[items.length - 1];
      prev.focus();
    }else if(e.key === "Home"){
      e.preventDefault();
      items[0].focus();
    }else if(e.key === "End"){
      e.preventDefault();
      items[items.length - 1].focus();
    }
  }

  function onDocClickToCloseMenu(e){
    if($("overflowMenu").hidden) return;
    const menu = $("overflowMenu");
    const isInside = menu.contains(e.target);
    const isAnchor = MENU.anchorEl && MENU.anchorEl.contains(e.target);
    if(!isInside && !isAnchor){
      closeMenu();
    }
  }

  // ====== Pagination ======
  function getPagedRows(rows){
    PAGINATION.totalPages = Math.max(1, Math.ceil(rows.length / PAGINATION.pageSize));
    if(PAGINATION.page > PAGINATION.totalPages) PAGINATION.page = PAGINATION.totalPages;
    if(PAGINATION.page < 1) PAGINATION.page = 1;

    const start = (PAGINATION.page - 1) * PAGINATION.pageSize;
    const end = start + PAGINATION.pageSize;

    $("currentPageText").textContent = String(PAGINATION.page);
    $("totalPagesText").textContent = String(PAGINATION.totalPages);

    if(rows.length === 0){
      $("pageInfo").textContent = "0 results";
    }else{
      $("pageInfo").textContent = `${start + 1}-${Math.min(end, rows.length)} of ${rows.length} results`;
    }

    return rows.slice(start, end);
  }

