  // ====== CSV ======
  function csvEscape(v){
    const s = String(v ?? "");
    return `"${s.replace(/"/g,'""')}"`;
  }

  function exportFilteredLeadsCSV(){
    const rows = CURRENT_FILTERED_LEADS || [];
    if(rows.length === 0){ alert("No filtered leads to export."); return; }

    const header = ["CreatedAt","ListingTitle","ListingId","BuyerName","BuyerPhone","AssignedTo","Status","FollowUp","Notes","Message"];
    const lines = [];
    lines.push(header.map(csvEscape).join(","));

    rows.forEach(l => {
      const line = [
        fmtDate(l.createdAt),
        l.listingTitle || "",
        l.listingId || "",
        l.buyerName || "",
        l.buyerPhone || "",
        l.assignedTo || "",
        (l.status || "NEW"),
        l.followUp || "",
        l.notes || "",
        l.message || ""
      ];
      lines.push(line.map(csvEscape).join(","));
    });

    const csv = lines.join("\n");
    const blob = new Blob([csv], {type:"text/csv;charset=utf-8;"});
    const url = URL.createObjectURL(blob);

    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    const fname = `MEI_Leads_${yyyy}-${mm}-${dd}.csv`;

    const a = document.createElement("a");
    a.href = url;
    a.download = fname;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);

    addActivity(`CSV exported: ${fname}`, "info");
    toast(`⬇ Exported CSV: ${fname}`);
  }

  // ====== Backup JSON ======
  function exportAllJSON(){
    const payload = {
      exportedAt: new Date().toISOString(),
      app: "MEI Admin Dashboard",
      version: "upgrade-v2",
      data: {
        properties: getProps(),
        leads: getLeads(),
        brokers: getBrokers(),
        waTemplate: getWATemplate(),
        activities: getActivities()
      }
    };

    const blob = new Blob([JSON.stringify(payload, null, 2)], {type:"application/json;charset=utf-8;"});
    const url = URL.createObjectURL(blob);

    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    const fname = `MEI_Backup_${yyyy}-${mm}-${dd}.json`;

    const a = document.createElement("a");
    a.href = url;
    a.download = fname;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);

    addActivity(`JSON backup exported: ${fname}`, "info");
    toast("⬇ JSON backup exported", { type:"info" });
  }

  function triggerImportJSON(){
    $("importJSONFile").click();
  }

  function handleImportJSONFile(file){
    if(!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      try{
        const parsed = JSON.parse(String(reader.result || "{}"));
        const data = parsed && parsed.data ? parsed.data : parsed;

        if(!data || typeof data !== "object"){
          throw new Error("Invalid backup format");
        }

        if(Array.isArray(data.properties)) saveProps(data.properties);
        if(Array.isArray(data.leads)) saveLeads(data.leads);
        if(Array.isArray(data.brokers)) saveBrokers(data.brokers);
        if(typeof data.waTemplate === "string") localStorage.setItem(WA_TEMPLATE_KEY, data.waTemplate);
        if(Array.isArray(data.activities)) saveActivities(data.activities);

        addActivity("JSON backup imported", "ok");
        toast("✅ Backup imported");
        refreshAll();
      }catch(err){
        console.error(err);
        toast("Import failed — invalid JSON", { type:"danger" });
      }finally{
        $("importJSONFile").value = "";
      }
    };
    reader.readAsText(file);
  }

  // ====== Activity ======
  function renderActivityFeed(){
    const feed = $("activityFeed");
    const items = getActivities();
    feed.innerHTML = "";

    if(!items.length){
      feed.appendChild(el("div", { class:"empty", text:"No recent activity yet." }));
      return;
    }

    items.slice(0, 8).forEach(item => {
      const tone = item.type === "warn" ? "border-color:rgba(255,200,0,.22);" :
                   item.type === "ok" ? "border-color:rgba(0,255,150,.22);" :
                   item.type === "danger" ? "border-color:rgba(255,0,90,.22);" :
                   "border-color:rgba(140,170,255,.22);";

      feed.appendChild(el("div", { class:"activityItem", style:tone }, [
        el("div", { style:"font-weight:900;", text:item.text || "Activity" }),
        el("div", { class:"mini", style:"margin-top:6px;", text:fmtDate(item.at) })
      ]));
    });
  }

  // ====== Summary render ======
  function renderPipelineSummary(){
    const box = $("pipelineSummary");
    const leads = getLeads();

    const total = leads.length;
    const fresh = leads.filter(l => (l.status || "").toUpperCase() === "NEW").length;
    const contacted = leads.filter(l => (l.status || "").toUpperCase() === "CONTACTED").length;
    const closed = leads.filter(l => (l.status || "").toUpperCase() === "CLOSED").length;
    const archived = leads.filter(l => (l.status || "").toUpperCase() === "ARCHIVED").length;

    box.innerHTML = "";

    const items = [
      { label:"NEW", val:fresh },
      { label:"CONTACTED", val:contacted },
      { label:"CLOSED", val:closed },
      { label:"ARCHIVED", val:archived },
      { label:"TOTAL", val:total }
    ];

    items.forEach(x => {
      box.appendChild(el("div", { class:"summaryItem" }, [
        el("div", { class:"mini", text:x.label }),
        el("div", { class:"summaryMetric", text:String(x.val) })
      ]));
    });
  }

  function renderTodaySnapshot(){
    const leads = getLeads();
    $("todayDueCount").textContent = String(leads.filter(isDueToday).length);
    $("unassignedCount").textContent = String(leads.filter(l => !(l.assignedTo || "").trim()).length);
    $("contactedTodayCount").textContent = String(leads.filter(isContactedToday).length);
  }

  function refreshStats(){
    const leads = getLeads();
    const props = getProps();
    const brokers = getBrokers();

    $("statTotalLeads").textContent = String(leads.length);
    $("statOverdue").textContent = String(leads.filter(isOverdue).length);
    $("statPending").textContent = String(props.filter(p => (p.status || "pending").toLowerCase() === "pending").length);
    $("statApproved").textContent = String(props.filter(p => (p.status || "").toLowerCase() === "approved").length);
    $("statBrokers").textContent = String(brokers.length);
  }

  // ====== Refresh + Reset ======
  function refreshAll(){
    syncBrokerDropdowns();
    $("waTemplate").value = getWATemplate();
    updatePreview();
    refreshProps();
    refreshLeads();
    renderCurrentUser();
    renderBrokerSummary();
    renderActivityFeed();
    renderPipelineSummary();
    renderTodaySnapshot();
    refreshStats();
  }

  function resetDemo(){
    const typed = prompt("Type RESET to confirm demo reset (clears local data).");
    if(String(typed || "").trim().toUpperCase() !== "RESET"){
      toast("Reset cancelled", { type:"warn" });
      return;
    }
    localStorage.removeItem(PROPS_KEY);
    localStorage.removeItem(LEADS_KEY);
    localStorage.removeItem(WA_TEMPLATE_KEY);
    localStorage.removeItem(BROKERS_KEY);
    localStorage.removeItem(ACTIVITY_KEY);
    addActivity("Demo reset completed", "warn");
    toast("🧨 Reset done", { type:"warn" });
    refreshAll();
  }

  function seedSampleData(){
    const hasLeads = getLeads().length > 0;
    const hasProps = getProps().length > 0;

    if(hasLeads || hasProps){
      if(!confirm("Sample data already exists. Add more sample data anyway?")) return;
    }

    if(getBrokers().length === 0){
      saveBrokers(["Raj","Karthik","Priya"]);
    }

    const props = getProps();
    props.push(
      normalizeProp({ title:"2BHK Whitefield", city:"Bangalore", area:"Whitefield", price:"6200000", status:"pending" }),
      normalizeProp({ title:"Villa Sarjapur", city:"Bangalore", area:"Sarjapur", price:"14500000", status:"approved", approvedAt:new Date().toISOString() }),
      normalizeProp({ title:"Plot OMR", city:"Chennai", area:"OMR", price:"3500000", status:"pending" })
    );
    saveProps(props);

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate()+1);

    const tY = tomorrow.getFullYear();
    const tM = String(tomorrow.getMonth()+1).padStart(2,"0");
    const tD = String(tomorrow.getDate()).padStart(2,"0");

    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate()-1);
    const yY = yesterday.getFullYear();
    const yM = String(yesterday.getMonth()+1).padStart(2,"0");
    const yD = String(yesterday.getDate()).padStart(2,"0");

    const leads = getLeads();
    leads.push(
      normalizeLead({
        listingTitle:"2BHK Whitefield",
        listingId:"WF-201",
        buyerName:"Arun",
        buyerPhone:"9876543210",
        status:"NEW",
        assignedTo:"Raj",
        followUp:`${tY}-${tM}-${tD}`,
        message:"Need a site visit on weekend"
      }),
      normalizeLead({
        listingTitle:"Villa Sarjapur",
        listingId:"SP-811",
        buyerName:"Meena",
        buyerPhone:"9123456780",
        status:"CONTACTED",
        assignedTo:"Priya",
        followUp:todayYMD(),
        notes:"Budget approved. Wants loan support."
      }),
      normalizeLead({
        listingTitle:"Plot OMR",
        listingId:"OMR-119",
        buyerName:"Rahul",
        buyerPhone:"9012345678",
        status:"NEW",
        assignedTo:"",
        followUp:`${yY}-${yM}-${yD}`,
        notes:"Asked for final negotiation."
      })
    );
    saveLeads(leads);

    addActivity("Sample data seeded", "ok");
    toast("✨ Sample data added");
    refreshAll();
  }

  // ====== Quick filters ======
  function setQuickFilter(mode){
    QUICK.overdueOnly = false;
    QUICK.dueTodayOnly = false;
    QUICK.unassignedOnly = false;

    if(mode === "OVERDUE") QUICK.overdueOnly = true;
    if(mode === "DUE_TODAY") QUICK.dueTodayOnly = true;
    if(mode === "UNASSIGNED") QUICK.unassignedOnly = true;

    document.querySelectorAll("[data-qfilter]").forEach(btn => {
      btn.classList.toggle("active", btn.getAttribute("data-qfilter") === mode && mode !== "CLEAR");
    });

    PAGINATION.page = 1;
    refreshLeads();
  }

  // ====== Dispatcher ======
  function dispatchAction(action){
    switch(action){
      case "refreshAll": refreshAll(); break;
      case "resetDemo": resetDemo(); break;
      case "addBroker": addBroker(); break;
      case "seedBrokers": seedBrokers(); break;
      case "saveWATemplate": saveWATemplateFn(); break;
      case "resetWATemplate": resetWATemplate(); break;
      case "updatePreview": updatePreview(); break;
      case "copyPreview": copyPreview(); break;
      case "refreshLeads": refreshLeads(); break;
      case "clearClosedLeads": clearClosedLeads(); break;
      case "exportCSV": exportFilteredLeadsCSV(); break;
      case "closeLeadModal": closeLeadModal(); break;
      case "saveLeadModal": saveLeadModal(); break;
      case "exportJSON": exportAllJSON(); break;
      case "triggerImportJSON": triggerImportJSON(); break;
      case "seedSampleData": seedSampleData(); break;
      case "logoutUser": logoutUserLocal(); break;
      case "prevPage":
        PAGINATION.page = Math.max(1, PAGINATION.page - 1);
        refreshLeads();
        break;
      case "nextPage":
        PAGINATION.page = Math.min(PAGINATION.totalPages, PAGINATION.page + 1);
        refreshLeads();
        break;
      default: break;
    }
  }

  // ====== Init ======
  function init(){
    $("toastAction").addEventListener("click", onToastAction);

    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-action]");
      if(!btn) return;
      const act = btn.getAttribute("data-action");
      if(!act) return;
      dispatchAction(act);
    });

    document.querySelectorAll("[data-insert]").forEach(b => {
      b.addEventListener("click", () => {
        insertAtCursor($("waTemplate"), b.getAttribute("data-insert"));
        updatePreview();
      });
    });

    $("leadSearch").addEventListener("input", () => {
      clearTimeout(LEAD_SEARCH_TIMER);
      LEAD_SEARCH_TIMER = setTimeout(() => {
        PAGINATION.page = 1;
        refreshLeads();
      }, 180);
    });

    $("brokerFilter").addEventListener("change", () => {
      PAGINATION.page = 1;
      refreshLeads();
    });
    $("statusFilter").addEventListener("change", () => {
      PAGINATION.page = 1;
      refreshLeads();
    });
    $("overdueFilter").addEventListener("change", () => {
      PAGINATION.page = 1;
      refreshLeads();
    });
    $("sortFilter").addEventListener("change", () => {
      PAGINATION.page = 1;
      refreshLeads();
    });

    document.querySelectorAll("[data-qfilter]").forEach(btn => {
      btn.addEventListener("click", () => {
        const mode = btn.getAttribute("data-qfilter");
        if(mode === "CLEAR") setQuickFilter("CLEAR");
        else setQuickFilter(mode);
      });
    });

    $("waTemplate").addEventListener("input", updatePreview);

    document.addEventListener("keydown", onMenuKeydown);
    document.addEventListener("click", onDocClickToCloseMenu);
    document.addEventListener("keydown", trapFocusInModal);

    $("leadModalBack").addEventListener("mousedown", (e) => {
      if(e.target === $("leadModalBack")) closeLeadModal();
    });

    $("importJSONFile").addEventListener("change", (e) => {
      const file = e.target.files && e.target.files[0];
      handleImportJSONFile(file);
    });

    $("pageSizeSelect").addEventListener("change", () => {
      PAGINATION.pageSize = Math.max(1, Number($("pageSizeSelect").value || 20));
      PAGINATION.page = 1;
      refreshLeads();
    });

    $("brokerName").addEventListener("keydown", (e) => {
      if(e.key === "Enter"){
        e.preventDefault();
        addBroker();
      }
    });

    document.addEventListener("keydown", (e) => {
      if(e.key === "/" && document.activeElement !== $("leadSearch")){
        const tag = (document.activeElement && document.activeElement.tagName) || "";
        const isTypingField = ["INPUT","TEXTAREA","SELECT"].includes(tag);
        if(!isTypingField){
          e.preventDefault();
          $("leadSearch").focus();
        }
      }

      if(e.altKey && (e.key === "r" || e.key === "R")){
        e.preventDefault();
        refreshAll();
        toast("🔄 Refreshed", { type:"info" });
      }
    });

    refreshAll();
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
