<!doctype html>
<html lang="ta">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>MEI Admin Dashboard</title>
  <style>
    :root{
      --bg:#0b1220; --card:#121b2f; --line:rgba(255,255,255,.10);
      --txt:#e8eefc; --mut:rgba(232,238,252,.75); --pill:rgba(255,255,255,.08);
      --radius:16px;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,Arial;background:var(--bg);color:var(--txt)}
    .wrap{max-width:1200px;margin:0 auto;padding:20px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:16px}
    .top{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
    .h1{font-size:26px;font-weight:900;letter-spacing:.2px}
    .muted{opacity:.75}
    .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    a.link{color:var(--txt);opacity:.9;text-decoration:none;padding:8px 12px;border:1px solid var(--line);border-radius:12px;background:rgba(255,255,255,.03)}
    a.link:hover{opacity:1}
    button{
      padding:9px 12px;border-radius:12px;border:1px solid var(--line);
      background:rgba(255,255,255,.06);color:var(--txt);cursor:pointer;font-weight:700
    }
    button:hover{background:rgba(255,255,255,.10)}
    .danger{border-color:rgba(255,0,90,.25);background:rgba(255,0,90,.10)}
    .danger:hover{background:rgba(255,0,90,.16)}
    .ok{border-color:rgba(0,255,150,.25);background:rgba(0,255,150,.10)}
    .ok:hover{background:rgba(0,255,150,.16)}
    .warn{border-color:rgba(255,200,0,.25);background:rgba(255,200,0,.10)}
    .warn:hover{background:rgba(255,200,0,.16)}

    .grid2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:12px}
    @media (max-width:900px){.grid2{grid-template-columns:1fr}}

    table{width:100%;border-collapse:collapse}
    th,td{padding:10px;vertical-align:top}
    thead th{opacity:.85;text-align:left;border-bottom:1px solid var(--line)}
    tbody tr{border-top:1px solid rgba(255,255,255,.08)}

    .pill{display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;background:var(--pill);border:1px solid var(--line);opacity:.95}
    .mini{font-size:12px;opacity:.75}
    .title{font-weight:900}
    .nowrap{white-space:nowrap}
    .toast{
      display:none;margin-top:10px;padding:10px 12px;border-radius:12px;
      border:1px solid rgba(0,255,150,.22);background:rgba(0,255,150,.10)
    }
    .overdueRow{
      background:linear-gradient(90deg, rgba(255,0,90,.10), transparent 45%);
      outline:1px solid rgba(255,0,90,.18);
      outline-offset:-1px;
    }

    .modalBack{display:none; position:fixed; inset:0; background:rgba(0,0,0,.55); padding:20px;}
    .modalCard{max-width:680px; margin:6vh auto; background:var(--card); border:1px solid rgba(255,255,255,.12); border-radius:16px; padding:16px;}

    input, select, textarea{
      width:100%; padding:10px; border-radius:12px;
      border:1px solid rgba(255,255,255,.12); background:#0b1220; color:var(--txt); outline:none;
    }
    textarea{resize:vertical}

    .filterBar{
      display:grid;
      grid-template-columns: 1.2fr .7fr .7fr .7fr .55fr;
      gap:10px;
      margin-top:12px;
    }
    @media (max-width:1100px){ .filterBar{grid-template-columns:1fr 1fr;} }
    @media (max-width:560px){ .filterBar{grid-template-columns:1fr;} }

    .templateGrid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:12px;
      margin-top:12px;
    }
    @media (max-width:900px){ .templateGrid{grid-template-columns:1fr;} }

    .brokerGrid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:12px;
      margin-top:12px;
    }
    @media (max-width:900px){ .brokerGrid{grid-template-columns:1fr;} }

    .chip{
      display:inline-flex; gap:8px; align-items:center;
      padding:6px 10px; border-radius:999px;
      background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.12);
      margin:4px 6px 0 0;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="top">
        <div>
          <div class="h1">MEI — Admin Dashboard</div>
          <div class="muted">Broker Master + Assign + Leads CRM (Template/Copy/Auto-log)</div>
        </div>
        <div class="row">
          <a class="link" href="add-property.html">➕ Add Property</a>
          <a class="link" href="buyer.html">👤 Buyer Portal</a>
          <a class="link" href="today.html">📅 Today</a>
          <button onclick="refreshAll()">🔄 Refresh</button>
          <button class="danger" onclick="resetDemo()">🧨 Reset (demo)</button>
        </div>
      </div>
      <div id="toast" class="toast">✅ Updated</div>
    </div>

    <!-- Broker Master -->
    <div class="card" style="margin-top:12px;">
      <div class="top">
        <div>
          <div class="h1" style="font-size:18px;">Broker Master</div>
          <div class="muted">Brokers list → Assign dropdown + Filter (scale ready)</div>
        </div>
        <div class="row">
          <button class="ok" onclick="addBroker()">➕ Add Broker</button>
          <button onclick="seedBrokers()">✨ Seed Demo</button>
        </div>
      </div>

      <div class="brokerGrid">
        <div>
          <div class="mini" style="margin-bottom:6px;">Add broker name</div>
          <input id="brokerName" placeholder="Eg: Raj / Karthik / Priya">
          <div class="mini" style="margin-top:8px;">Tip: short unique names better.</div>
        </div>
        <div>
          <div class="mini" style="margin-bottom:6px;">Current brokers</div>
          <div id="brokerChips"></div>
          <div class="mini" style="margin-top:8px;">Deleting broker won’t delete leads; it only removes from list.</div>
        </div>
      </div>
    </div>

    <!-- WhatsApp Template -->
    <div class="card" style="margin-top:12px;">
      <div class="top">
        <div>
          <div class="h1" style="font-size:18px;">WhatsApp Template</div>
          <div class="muted">
            Placeholders: <span class="pill">{buyer}</span> <span class="pill">{listing}</span>
            <span class="pill">{phone}</span> <span class="pill">{date}</span>
          </div>
        </div>
        <div class="row">
          <button class="ok" onclick="saveWATemplate()">💾 Save Template</button>
          <button onclick="resetWATemplate()">↩ Reset Default</button>
        </div>
      </div>

      <div class="templateGrid">
        <div>
          <div class="mini" style="margin-bottom:6px;">Template message</div>
          <textarea id="waTemplate" rows="7"></textarea>
          <div class="mini" style="margin-top:6px;">Tip: Short + clear = more replies.</div>
        </div>

        <div>
          <div class="mini" style="margin-bottom:6px;">Preview (sample)</div>
          <div class="card" style="background:rgba(255,255,255,.03);">
            <div class="mini">Sample Buyer: Arun • Listing: 2BHK Whitefield • Phone: 9876543210</div>
            <div id="waPreview" style="white-space:pre-wrap; margin-top:10px; line-height:1.35;"></div>
          </div>
          <div class="row" style="margin-top:10px;">
            <button onclick="updatePreview()">🔍 Update Preview</button>
            <button class="ok" onclick="copyPreview()">📋 Copy Preview</button>
          </div>
        </div>
      </div>
    </div>

    <!-- APPROVAL + LISTINGS -->
    <div class="grid2">
      <div class="card">
        <div class="top">
          <div>
            <div class="h1" style="font-size:18px;">Pending Approvals</div>
            <div class="muted">Admin only: approve/reject</div>
          </div>
          <div class="row">
            <span class="pill">Pending: <b id="pendingCount">0</b></span>
          </div>
        </div>

        <div style="overflow:auto;margin-top:10px;">
          <table>
            <thead>
              <tr>
                <th>Listing</th>
                <th class="nowrap">Actions</th>
              </tr>
            </thead>
            <tbody id="pendingBody"></tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="top">
          <div>
            <div class="h1" style="font-size:18px;">Approved Listings</div>
            <div class="muted">Buyer portal shows ONLY these</div>
          </div>
          <div class="row">
            <span class="pill">Approved: <b id="approvedCount">0</b></span>
          </div>
        </div>

        <div style="overflow:auto;margin-top:10px;">
          <table>
            <thead>
              <tr>
                <th>Listing</th>
                <th class="nowrap">Manage</th>
              </tr>
            </thead>
            <tbody id="approvedBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- LEADS -->
    <div class="card" style="margin-top:12px;">
      <div class="top">
        <div>
          <div class="h1" style="font-size:18px;">Leads — Mini CRM</div>
          <div class="muted">Search + Filters + Broker Assign/Filter + Export + WhatsApp/Copy + Auto Log</div>
        </div>
        <div class="row">
          <span class="pill">Total: <b id="leadCount">0</b></span>
          <span class="pill">Overdue: <b id="overdueCount">0</b></span>
          <button onclick="refreshLeads()">Refresh</button>
          <button class="warn" onclick="clearClosedLeads()">Clear Closed/Archived</button>
        </div>
      </div>

      <div class="filterBar">
        <input id="leadSearch" placeholder="Search listing / phone / buyer / notes..." oninput="refreshLeads()">

        <select id="brokerFilter" onchange="refreshLeads()">
          <option value="ALL">All Brokers</option>
          <option value="__UNASSIGNED__">Unassigned</option>
        </select>

        <select id="statusFilter" onchange="refreshLeads()">
          <option value="ALL">All Status</option>
          <option value="NEW">NEW</option>
          <option value="CONTACTED">CONTACTED</option>
          <option value="CLOSED">CLOSED</option>
          <option value="ARCHIVED">ARCHIVED</option>
        </select>

        <select id="overdueFilter" onchange="refreshLeads()">
          <option value="ALL">All</option>
          <option value="OVERDUE">Overdue only</option>
          <option value="NOT_OVERDUE">Not overdue</option>
        </select>

        <button class="ok" onclick="exportFilteredLeadsCSV()">⬇ Export CSV</button>
      </div>

      <div style="overflow:auto;margin-top:12px;">
        <table style="min-width:1600px;">
          <thead>
            <tr>
              <th class="nowrap">Date</th>
              <th>Listing</th>
              <th>Buyer</th>
              <th class="nowrap">Phone</th>
              <th class="nowrap">Assigned</th>
              <th>Status</th>
              <th class="nowrap">Follow-up</th>
              <th>Notes</th>
              <th class="nowrap">Actions</th>
            </tr>
          </thead>
          <tbody id="leadsBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Lead Edit Modal -->
  <div id="leadModalBack" class="modalBack">
    <div class="modalCard">
      <div class="top">
        <div>
          <div class="h1" style="font-size:18px;">Edit Lead</div>
          <div id="mListing" class="muted"></div>
        </div>
        <div class="row">
          <button onclick="closeLeadModal()">✕ Close</button>
        </div>
      </div>

      <div style="display:grid; gap:10px; margin-top:12px;">
        <div>
          <label class="mini">Follow-up date</label>
          <input id="mFollowUp" type="date">
        </div>
        <div>
          <label class="mini">Assigned to (optional)</label>
          <select id="mAssigned"></select>
        </div>
        <div>
          <label class="mini">Notes</label>
          <textarea id="mNotes" rows="6" placeholder="Call summary / site visit / budget / next step..."></textarea>
        </div>

        <div class="row">
          <button class="ok" onclick="saveLeadModal()">✅ Save</button>
          <button class="danger" onclick="closeLeadModal()">Cancel</button>
        </div>
      </div>
    </div>
  </div>

<script>
  // ====== Storage Keys ======
  const PROPS_KEY = "mei_properties_v1";
  const LEADS_KEY = "mei_leads_v1";
  const WA_TEMPLATE_KEY = "mei_whatsapp_template_v1";
  const BROKERS_KEY = "mei_brokers_v1";

  let MODAL_LEAD_ID = null;
  let CURRENT_FILTERED_LEADS = [];

  const $ = (id)=>document.getElementById(id);

  // ====== Helpers ======
  function escapeHtml(str){
    return String(str ?? "").replace(/[&<>"']/g, s => ({
      "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"
    }[s]));
  }
  function toast(msg="✅ Updated"){
    const el = $("toast");
    el.textContent = msg;
    el.style.display = "block";
    setTimeout(()=> el.style.display="none", 1100);
  }
  function fmtDate(iso){
    try { return new Date(iso).toLocaleString(); }
    catch(e){ return iso || ""; }
  }
  function todayYMD(){
    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    return `${yyyy}-${mm}-${dd}`;
  }
  function isOverdue(lead){
    const status = (lead.status || "").toUpperCase();
    if(["CLOSED","ARCHIVED"].includes(status)) return false;
    if(!lead.followUp) return false;
    return lead.followUp < todayYMD();
  }
  function badge(status){
    const s = (status || "NEW").toUpperCase();
    const map = {
      NEW: "background:rgba(0,153,255,.15); border:1px solid rgba(0,153,255,.25);",
      CONTACTED: "background:rgba(255,200,0,.12); border:1px solid rgba(255,200,0,.22);",
      CLOSED: "background:rgba(0,255,150,.12); border:1px solid rgba(0,255,150,.25);",
      ARCHIVED: "background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12);"
    };
    return `<span class="pill" style="${map[s] || map.NEW}">${s}</span>`;
  }

  // ====== Clipboard ======
  async function copyToClipboard(text){
    const t = String(text ?? "");
    if(!t.trim()){ alert("Nothing to copy"); return false; }
    try{
      if(navigator.clipboard && window.isSecureContext){
        await navigator.clipboard.writeText(t);
        return true;
      }
    }catch(e){}
    try{
      const ta = document.createElement("textarea");
      ta.value = t;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      ta.style.top = "-9999px";
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      const ok = document.execCommand("copy");
      ta.remove();
      return ok;
    }catch(e){
      return false;
    }
  }

  // ====== Broker Master ======
  function getBrokers(){ return JSON.parse(localStorage.getItem(BROKERS_KEY) || "[]"); }
  function saveBrokers(list){
    const cleaned = Array.from(new Set((list || [])
      .map(x => String(x||"").trim())
      .filter(Boolean)
    ));
    localStorage.setItem(BROKERS_KEY, JSON.stringify(cleaned));
  }

  function renderBrokerChips(){
    const brokers = getBrokers();
    const wrap = $("brokerChips");
    if(brokers.length === 0){
      wrap.innerHTML = `<div class="mini" style="opacity:.8">No brokers yet. Add one.</div>`;
      return;
    }
    wrap.innerHTML = brokers.map(b => `
      <span class="chip">
        <span style="font-weight:900">${escapeHtml(b)}</span>
        <button class="danger" style="padding:4px 8px" onclick="deleteBroker('${escapeHtml(b)}')">✕</button>
      </span>
    `).join("");
  }

  function addBroker(){
    const name = ($("brokerName").value || "").trim();
    if(!name){ alert("Enter broker name"); return; }
    const brokers = getBrokers();
    brokers.push(name);
    saveBrokers(brokers);
    $("brokerName").value = "";
    toast("✅ Broker added");
    syncBrokerDropdowns();
    refreshLeads();
  }

  function deleteBroker(name){
    if(!confirm(`Delete broker "${name}" from list?`)) return;
    const brokers = getBrokers().filter(b => b !== name);
    saveBrokers(brokers);
    toast("🧹 Broker removed");
    syncBrokerDropdowns();
    refreshLeads();
  }

  function seedBrokers(){
    const brokers = getBrokers();
    if(brokers.length) { toast("Already has brokers"); return; }
    saveBrokers(["Raj","Karthik","Priya"]);
    toast("✨ Demo brokers added");
    syncBrokerDropdowns();
    refreshLeads();
  }

  function syncBrokerDropdowns(){
    renderBrokerChips();

    // Filter dropdown
    const bf = $("brokerFilter");
    const current = bf.value || "ALL";
    bf.innerHTML = `
      <option value="ALL">All Brokers</option>
      <option value="__UNASSIGNED__">Unassigned</option>
      ${getBrokers().map(b => `<option value="${escapeHtml(b)}">${escapeHtml(b)}</option>`).join("")}
    `;
    bf.value = (Array.from(bf.options).some(o => o.value === current)) ? current : "ALL";

    // Modal dropdown
    const md = $("mAssigned");
    const curM = md.value || "";
    md.innerHTML = `
      <option value="">Unassigned</option>
      ${getBrokers().map(b => `<option value="${escapeHtml(b)}">${escapeHtml(b)}</option>`).join("")}
    `;
    md.value = (Array.from(md.options).some(o => o.value === curM)) ? curM : "";
  }

  // ====== WhatsApp Template ======
  function defaultWATemplate(){
    return `Hello {buyer},

Thanks for your interest in "{listing}".

This is MEI Realty. Please share your preferred time to discuss today.

- MEI`;
  }
  function getWATemplate(){
    return localStorage.getItem(WA_TEMPLATE_KEY) || defaultWATemplate();
  }
  function saveWATemplate(){
    const val = ($("waTemplate").value || "").trim();
    if(!val){ alert("Template cannot be empty"); return; }
    localStorage.setItem(WA_TEMPLATE_KEY, val);
    toast("💾 WhatsApp template saved");
    updatePreview();
  }
  function resetWATemplate(){
    localStorage.setItem(WA_TEMPLATE_KEY, defaultWATemplate());
    $("waTemplate").value = getWATemplate();
    toast("↩ Template reset to default");
    updatePreview();
  }
  function applyTemplate(tpl, lead){
    const dateStr = new Date().toLocaleDateString();
    return String(tpl || "")
      .replaceAll("{buyer}", lead.buyerName || "")
      .replaceAll("{listing}", lead.listingTitle || "property")
      .replaceAll("{phone}", lead.buyerPhone || "")
      .replaceAll("{date}", dateStr);
  }
  function updatePreview(){
    const tpl = ($("waTemplate").value || "").trim() || defaultWATemplate();
    const sample = { buyerName:"Arun", listingTitle:"2BHK Whitefield", buyerPhone:"9876543210" };
    $("waPreview").textContent = applyTemplate(tpl, sample);
  }
  async function copyPreview(){
    const txt = $("waPreview").textContent || "";
    const ok = await copyToClipboard(txt);
    if(ok) toast("📋 Preview copied");
    else alert("Copy failed.");
  }

  // ====== Data ======
  function getProps(){ return JSON.parse(localStorage.getItem(PROPS_KEY) || "[]"); }
  function saveProps(props){ localStorage.setItem(PROPS_KEY, JSON.stringify(props)); }

  function getLeads(){ return JSON.parse(localStorage.getItem(LEADS_KEY) || "[]"); }
  function saveLeads(leads){ localStorage.setItem(LEADS_KEY, JSON.stringify(leads)); }

  function migrateLeadDefaults(lead){
    if(lead.notes == null) lead.notes = "";
    if(lead.followUp == null) lead.followUp = "";
    if(lead.lastContactedAt == null) lead.lastContactedAt = "";
    if(lead.updatedAt == null) lead.updatedAt = "";
    if(lead.status == null) lead.status = "NEW";
    if(lead.assignedTo == null) lead.assignedTo = "";
    return lead;
  }

  // ====== Auto Log Communication ======
  function autoLogCommunication(leadId, type){
    const leads = getLeads().map(migrateLeadDefaults);
    const idx = leads.findIndex(l => l.id === leadId);
    if(idx === -1) return;

    const now = new Date();
    const logLine = `[${now.toLocaleString()}] ${type}`;

    const existing = (leads[idx].notes || "").trim();
    leads[idx].notes = existing ? (existing + "\n" + logLine) : logLine;

    leads[idx].status = "CONTACTED";
    leads[idx].lastContactedAt = now.toISOString();
    leads[idx].updatedAt = now.toISOString();

    if(!leads[idx].followUp){
      const d = new Date();
      d.setDate(d.getDate()+1);
      const yyyy = d.getFullYear();
      const mm = String(d.getMonth()+1).padStart(2,"0");
      const dd = String(d.getDate()).padStart(2,"0");
      leads[idx].followUp = `${yyyy}-${mm}-${dd}`;
    }

    saveLeads(leads);
  }

  // ====== WhatsApp + Copy ======
  function cleanPhoneForWA(phone){
    const clean = String(phone || "").replace(/[^\d]/g,'');
    if(clean.length === 10) return "91" + clean; // India default
    return clean;
  }
  function buildLeadMessage(buyerName, buyerPhone, listingTitle){
    const tpl = getWATemplate();
    return applyTemplate(tpl, { buyerName, buyerPhone, listingTitle });
  }
  function openWhatsApp(phone, buyerName, listingTitle, leadId){
    if(!phone){ alert("No phone number"); return; }
    const finalPhone = cleanPhoneForWA(phone);
    const message = buildLeadMessage(buyerName, phone, listingTitle);
    window.open(`https://wa.me/${finalPhone}?text=${encodeURIComponent(message)}`, "_blank");

    autoLogCommunication(leadId, "WhatsApp message sent");
    toast("💬 WhatsApp opened + Logged");
    refreshLeads();
  }
  async function copyLeadMessage(phone, buyerName, listingTitle, leadId){
    const message = buildLeadMessage(buyerName, phone, listingTitle);
    const ok = await copyToClipboard(message);
    if(ok){
      autoLogCommunication(leadId, "Message copied");
      toast("📋 Message copied + Logged");
      refreshLeads();
    }else{
      alert("Copy failed.");
    }
  }

  // ====== Properties ======
  function approveProp(id){
    const props = getProps();
    const i = props.findIndex(p => p.id === id);
    if(i === -1) return;
    props[i].status = "approved";
    props[i].approvedAt = new Date().toISOString();
    saveProps(props);
    toast("✅ Approved");
    refreshProps();
  }
  function rejectProp(id){
    const props = getProps();
    const i = props.findIndex(p => p.id === id);
    if(i === -1) return;
    props[i].status = "rejected";
    props[i].rejectedAt = new Date().toISOString();
    saveProps(props);
    toast("🗑️ Rejected");
    refreshProps();
  }
  function deleteProp(id){
    const props = getProps().filter(p => p.id !== id);
    saveProps(props);
    toast("🧹 Deleted");
    refreshProps();
  }
  function rowListing(p){
    const title = escapeHtml(p.title || p.name || "Listing");
    const meta = [p.city, p.area, p.price ? ("₹"+p.price) : ""].filter(Boolean).map(escapeHtml).join(" • ");
    return `
      <div class="title">${title}</div>
      <div class="mini">${meta || "—"}</div>
      <div class="mini">ID: ${escapeHtml(p.id || "-")}</div>
    `;
  }
  function refreshProps(){
    const props = getProps();
    const pending = props.filter(p => (p.status || "pending").toLowerCase() === "pending");
    const approved = props.filter(p => (p.status || "").toLowerCase() === "approved");

    $("pendingCount").textContent = pending.length;
    $("approvedCount").textContent = approved.length;

    $("pendingBody").innerHTML = pending.length ? pending.map(p => `
      <tr>
        <td>${rowListing(p)}</td>
        <td class="nowrap">
          <div class="row">
            <button class="ok" onclick="approveProp('${escapeHtml(p.id)}')">Approve</button>
            <button class="danger" onclick="rejectProp('${escapeHtml(p.id)}')">Reject</button>
          </div>
        </td>
      </tr>
    `).join("") : `<tr><td colspan="2" style="opacity:.75;padding:14px;">No pending approvals.</td></tr>`;

    $("approvedBody").innerHTML = approved.length ? approved.map(p => `
      <tr>
        <td>${rowListing(p)}<div class="mini">Approved: ${escapeHtml(fmtDate(p.approvedAt || ""))}</div></td>
        <td class="nowrap">
          <div class="row">
            <button class="warn" onclick="approveProp('${escapeHtml(p.id)}')">Re-Approve</button>
            <button class="danger" onclick="deleteProp('${escapeHtml(p.id)}')">Delete</button>
          </div>
        </td>
      </tr>
    `).join("") : `<tr><td colspan="2" style="opacity:.75;padding:14px;">No approved listings yet.</td></tr>`;
  }

  // ====== Assign Broker ======
  function setLeadAssigned(id, broker){
    const leads = getLeads().map(migrateLeadDefaults);
    const idx = leads.findIndex(l => l.id === id);
    if(idx === -1) return;
    leads[idx].assignedTo = String(broker || "").trim();
    leads[idx].updatedAt = new Date().toISOString();
    saveLeads(leads);
    toast("👤 Assigned updated");
    refreshLeads();
  }

  // ====== Lead actions ======
  function setLeadStatus(id, status){
    const leads = getLeads().map(migrateLeadDefaults);
    const idx = leads.findIndex(x => x.id === id);
    if(idx === -1) return;

    leads[idx].status = status;
    leads[idx].updatedAt = new Date().toISOString();

    if(String(status).toUpperCase() === "CONTACTED"){
      leads[idx].lastContactedAt = new Date().toISOString();
      if(!leads[idx].followUp){
        const d = new Date(); d.setDate(d.getDate()+1);
        const yyyy = d.getFullYear();
        const mm = String(d.getMonth()+1).padStart(2,"0");
        const dd = String(d.getDate()).padStart(2,"0");
        leads[idx].followUp = `${yyyy}-${mm}-${dd}`;
      }
    }

    saveLeads(leads);
    toast("✅ Lead updated");
    refreshLeads();
  }
  function archiveLead(id){ setLeadStatus(id, "ARCHIVED"); }
  function clearClosedLeads(){
    const leads = getLeads().map(migrateLeadDefaults);
    const filtered = leads.filter(l => !["CLOSED","ARCHIVED"].includes((l.status||"").toUpperCase()));
    saveLeads(filtered);
    toast("🧹 Cleared closed/archived");
    refreshLeads();
  }

  // Modal
  function openLeadModal(id){
    const leads = getLeads().map(migrateLeadDefaults);
    const lead = leads.find(l => l.id === id);
    if(!lead) return;

    MODAL_LEAD_ID = id;
    $("mListing").textContent = `${lead.listingTitle || "Listing"} • ${lead.buyerName || ""} • ${lead.buyerPhone || ""}`;

    $("mFollowUp").value = lead.followUp || "";
    syncBrokerDropdowns();
    $("mAssigned").value = lead.assignedTo || "";
    $("mNotes").value = lead.notes || "";
    $("leadModalBack").style.display = "block";
  }
  function closeLeadModal(){
    $("leadModalBack").style.display = "none";
    MODAL_LEAD_ID = null;
  }
  function saveLeadModal(){
    if(!MODAL_LEAD_ID) return;
    const leads = getLeads().map(migrateLeadDefaults);
    const idx = leads.findIndex(l => l.id === MODAL_LEAD_ID);
    if(idx === -1) return;

    leads[idx].followUp = $("mFollowUp").value || "";
    leads[idx].assignedTo = ($("mAssigned").value || "").trim();
    leads[idx].notes = $("mNotes").value.trim();
    leads[idx].updatedAt = new Date().toISOString();

    saveLeads(leads);
    toast("✅ Saved");
    closeLeadModal();
    refreshLeads();
  }

  // Filters
  function leadMatchesSearch(lead, q){
    if(!q) return true;
    const hay = [
      lead.listingTitle, lead.listingId,
      lead.buyerName, lead.buyerPhone,
      lead.message, lead.notes,
      lead.assignedTo
    ].join(" ").toLowerCase();
    return hay.includes(q);
  }
  function applyLeadFilters(leadsRaw){
    const q = ($("leadSearch").value || "").trim().toLowerCase();
    const brokerF = ($("brokerFilter").value || "ALL");
    const statusF = ($("statusFilter").value || "ALL").toUpperCase();
    const odF = ($("overdueFilter").value || "ALL").toUpperCase();

    return leadsRaw
      .filter(l => leadMatchesSearch(l, q))
      .filter(l => {
        if(brokerF === "ALL") return true;
        if(brokerF === "__UNASSIGNED__") return !(l.assignedTo || "").trim();
        return (l.assignedTo || "") === brokerF;
      })
      .filter(l => statusF === "ALL" ? true : (l.status || "NEW").toUpperCase() === statusF)
      .filter(l => {
        if(odF === "ALL") return true;
        const od = isOverdue(l);
        if(odF === "OVERDUE") return od;
        if(odF === "NOT_OVERDUE") return !od;
        return true;
      });
  }

  function renderAssignSelect(lead){
    const brokers = getBrokers();
    const cur = (lead.assignedTo || "").trim();
    return `
      <select onchange="setLeadAssigned('${escapeHtml(lead.id)}', this.value)" style="min-width:160px">
        <option value="" ${cur===""?"selected":""}>Unassigned</option>
        ${brokers.map(b => `<option value="${escapeHtml(b)}" ${cur===b?"selected":""}>${escapeHtml(b)}</option>`).join("")}
      </select>
    `;
  }

  function refreshLeads(){
    const leadsRaw = getLeads().map(migrateLeadDefaults);
    saveLeads(leadsRaw);

    $("leadCount").textContent = leadsRaw.length;
    $("overdueCount").textContent = leadsRaw.filter(isOverdue).length;

    const leads = applyLeadFilters(leadsRaw);
    CURRENT_FILTERED_LEADS = leads;

    const tbody = $("leadsBody");
    if(leads.length === 0){
      tbody.innerHTML = `<tr><td colspan="9" style="padding:14px; opacity:.75;">No leads match your filters.</td></tr>`;
      return;
    }

    tbody.innerHTML = leads.map(l => {
      const overdueClass = isOverdue(l) ? "overdueRow" : "";
      const fu = l.followUp ? escapeHtml(l.followUp) : "—";
      const notesShow = (l.notes || "").trim() ? escapeHtml(l.notes.trim()) : "—";
      const lastC = l.lastContactedAt ? ("Last: " + escapeHtml(fmtDate(l.lastContactedAt))) : "";

      return `
        <tr class="${overdueClass}">
          <td class="nowrap">${escapeHtml(fmtDate(l.createdAt))}</td>
          <td>
            <div class="title">${escapeHtml(l.listingTitle || "Listing")}</div>
            <div class="mini">ID: ${escapeHtml(l.listingId || "-")}</div>
          </td>
          <td>${escapeHtml(l.buyerName || "-")}</td>
          <td class="nowrap">${escapeHtml(l.buyerPhone || "-")}</td>

          <td class="nowrap">
            ${renderAssignSelect(l)}
          </td>

          <td>
            ${badge(l.status)}
            ${isOverdue(l) ? `<div class="mini" style="margin-top:6px; color:rgba(255,0,90,.95); font-weight:800;">⚠ OVERDUE</div>` : ""}
          </td>

          <td class="nowrap">
            <div>${fu}</div>
            <div class="mini">${lastC}</div>
          </td>

          <td style="max-width:420px;">
            <div>${notesShow}</div>
          </td>

          <td class="nowrap">
            <div class="row">
              <a class="link" style="padding:6px 10px;" href="tel:${encodeURIComponent(l.buyerPhone || "")}">📞 Call</a>
              <button onclick="openWhatsApp('${escapeHtml(l.buyerPhone)}','${escapeHtml(l.buyerName)}','${escapeHtml(l.listingTitle)}','${escapeHtml(l.id)}')">💬 WhatsApp</button>
              <button class="ok" onclick="copyLeadMessage('${escapeHtml(l.buyerPhone)}','${escapeHtml(l.buyerName)}','${escapeHtml(l.listingTitle)}','${escapeHtml(l.id)}')">📋 Copy</button>
              <button onclick="openLeadModal('${escapeHtml(l.id)}')">✏️ Edit</button>
              <button onclick="setLeadStatus('${escapeHtml(l.id)}','CONTACTED')">Contacted</button>
              <button class="ok" onclick="setLeadStatus('${escapeHtml(l.id)}','CLOSED')">Close</button>
              <button class="danger" onclick="archiveLead('${escapeHtml(l.id)}')">Archive</button>
            </div>
          </td>
        </tr>

        ${(l.message && l.message.trim()) ? `
          <tr class="${overdueClass}">
            <td></td>
            <td colspan="8" style="opacity:.88; border-top:1px dashed rgba(255,255,255,.10);">
              📝 ${escapeHtml(l.message)}
            </td>
          </tr>` : ""}
      `;
    }).join("");
  }

  // Export CSV (filtered)
  function csvEscape(v){
    const s = String(v ?? "");
    return `"${s.replace(/"/g,'""')}"`;
  }
  function exportFilteredLeadsCSV(){
    const rows = CURRENT_FILTERED_LEADS || [];
    if(rows.length === 0){ alert("No filtered leads to export."); return; }

    const header = ["CreatedAt","ListingTitle","ListingId","BuyerName","BuyerPhone","AssignedTo","Status","FollowUp","Notes","Message"];
    const lines = [];
    lines.push(header.map(csvEscape).join(","));

    rows.forEach(l => {
      const line = [
        fmtDate(l.createdAt),
        l.listingTitle || "",
        l.listingId || "",
        l.buyerName || "",
        l.buyerPhone || "",
        l.assignedTo || "",
        (l.status || "NEW"),
        l.followUp || "",
        l.notes || "",
        l.message || ""
      ];
      lines.push(line.map(csvEscape).join(","));
    });

    const csv = lines.join("\n");
    const blob = new Blob([csv], {type:"text/csv;charset=utf-8;"});
    const url = URL.createObjectURL(blob);

    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth()+1).padStart(2,"0");
    const dd = String(d.getDate()).padStart(2,"0");
    const fname = `MEI_Leads_${yyyy}-${mm}-${dd}.csv`;

    const a = document.createElement("a");
    a.href = url;
    a.download = fname;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);

    toast(`⬇ Exported CSV: ${fname}`);
  }

  function refreshAll(){
    syncBrokerDropdowns();
    $("waTemplate").value = getWATemplate();
    updatePreview();
    refreshProps();
    refreshLeads();
  }

  function resetDemo(){
    if(!confirm("Reset demo data?")) return;
    localStorage.removeItem(PROPS_KEY);
    localStorage.removeItem(LEADS_KEY);
    localStorage.removeItem(WA_TEMPLATE_KEY);
    localStorage.removeItem(BROKERS_KEY);
    toast("🧨 Reset done");
    refreshAll();
  }

  document.addEventListener("DOMContentLoaded", refreshAll);
</script>
</body>
