    // Sample static listings (demo data)
    const listings = [
      { id:"p1", city:"Bangalore", locality:"Whitefield", type:"APARTMENT", price:8200000, area:1180, bhk:2, badge:"Verified", title:"2BHK near ITPL", note:"Gated • Lift • Parking" },
