      { id:"p3", city:"Bangalore", locality:"ITPL", type:"COMMERCIAL", price:15500000, area:920, bhk:null, badge:"Elite", title:"Office near ITPL", note:"High footfall • Clinic suitable" },
      { id:"p4", city:"Bangalore", locality:"Whitefield", type:"VILLA", price:26500000, area:2400, bhk:4, badge:"Elite", title:"4BHK Villa Whitefield", note:"Premium layout • Calm street" },
