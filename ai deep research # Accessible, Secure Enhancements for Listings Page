    ['bmin','bmax'].forEach(id => {
      document.getElementById(id).addEventListener('keypress', e => {
        if(e.key === 'Enter') applyFilters();
      });
    });

    // Initial render
    document.addEventListener("DOMContentLoaded", () => {
      applyFilters();
    });
  </script>
