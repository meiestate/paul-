    ];

    // Helper to format INR currency
    const formatINR = n => "₹" + Number(n).toLocaleString("en-IN");

    // Create a card element for a listing
    function createCard(item) {
      const cardDiv = document.createElement('div'); cardDiv.className = 'p';
      const imgDiv = document.createElement('div'); imgDiv.className = 'img';
      const bodyDiv = document.createElement('div'); bodyDiv.className = 'body';

      const priceDiv = document.createElement('div'); priceDiv.className = 'price';
      priceDiv.textContent = formatINR(item.price);

      const titleDiv = document.createElement('div');
      titleDiv.style.fontWeight = '900';
      titleDiv.style.margin = '6px 0 0';
      titleDiv.textContent = item.title;

      const addrDiv = document.createElement('div'); addrDiv.className = 'addr';
      addrDiv.textContent = `${item.locality}, ${item.city} • ${item.type}${item.bhk ? " • " + item.bhk + "BHK" : ""} • ${item.area} sqft`;

      const metaDiv = document.createElement('div'); metaDiv.className = 'meta';
      ["Approved","KYC "+item.badge,"Deal Room"].forEach(t => {
        const chip = document.createElement('span'); chip.className = 'chip'; chip.textContent = t;
        metaDiv.appendChild(chip);
      });

      const noteDiv = document.createElement('div'); noteDiv.className = 'addr';
      noteDiv.textContent = item.note;

      const actionsDiv = document.createElement('div'); actionsDiv.className = 'actions';
      const viewLink = document.createElement('a'); viewLink.className = 'btn small';
      // Open property detail (same origin) - no target blank
      viewLink.href = `property.html?id=${encodeURIComponent(item.id)}`;
      viewLink.textContent = 'View';
      const leadLink = document.createElement('a'); leadLink.className = 'btn primary small';
      leadLink.href = 'index.html#lead';
      leadLink.textContent = "I'm Interested";
      actionsDiv.appendChild(viewLink);
      actionsDiv.appendChild(leadLink);

      bodyDiv.appendChild(priceDiv);
      bodyDiv.appendChild(titleDiv);
      bodyDiv.appendChild(addrDiv);
      bodyDiv.appendChild(metaDiv);
      bodyDiv.appendChild(noteDiv);
      bodyDiv.appendChild(actionsDiv);

      cardDiv.appendChild(imgDiv);
      cardDiv.appendChild(bodyDiv);
      return cardDiv;
    }

    // Apply filters and render listings
    function applyFilters() {
      const city = document.getElementById('city').value;
      const locality = document.getElementById('locality').value;
      const ptype = document.getElementById('ptype').value;
      const bmin = Number(document.getElementById('bmin').value) || 0;
      const bmax = Number(document.getElementById('bmax').value) || 0;
      const sort = document.getElementById('sort').value;

      let results = listings.filter(l => l.city === city);
      if(locality) results = results.filter(l => l.locality === locality);
      if(ptype)   results = results.filter(l => l.type === ptype);
      if(bmin)    results = results.filter(l => l.price >= bmin);
      if(bmax)    results = results.filter(l => l.price <= bmax);

      // Sorting
      if(sort === "price_asc")      results.sort((a,b)=>a.price-b.price);
      if(sort === "price_desc")     results.sort((a,b)=>b.price-a.price);
      // 'new' leaves static order

      // Render grid
      const grid = document.getElementById('grid');
      grid.innerHTML = "";  // safe clear
      results.forEach(item => grid.appendChild(createCard(item)));
      document.getElementById('count').textContent = `${results.length} results`;
    }

    // Event handlers
    document.getElementById('applyBtn').addEventListener('click', applyFilters);
