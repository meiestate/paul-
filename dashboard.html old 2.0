              <button type="button" class="warn btnSmall" data-status-material="${escapeAttr(x.id)}" data-next="CONTACTED">Contacted</button>
              <button type="button" class="ok btnSmall" data-status-material="${escapeAttr(x.id)}" data-next="CLOSED">Close</button>
              <button type="button" class="danger btnSmall" data-status-material="${escapeAttr(x.id)}" data-next="ARCHIVED">Archive</button>
            </div>
