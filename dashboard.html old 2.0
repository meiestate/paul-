        if(x.notes){
          const tr2 = document.createElement("tr");
          tr2.innerHTML = `<td></td><td colspan="8" style="border-top:1px dashed rgba(255,255,255,.12);">📝 ${escapeHtml(x.notes)}</td>`;
          body.appendChild(tr2);
        }
      });
    }

    function setBuyerAssigned(id, broker){
      const list = getAllLeads();
      const idx = list.findIndex(x => x.id === id);
      if(idx === -1) return;
      list[idx].assignedTo = broker || "";
      list[idx].assignedBrokerName = broker || "";
      list[idx].updatedAt = new Date().toISOString();
      saveAllLeads(list);
      renderBuyerLeads();
      toast("Buyer lead assigned");
    }

    function setBuyerStatus(id, status){
      const list = getAllLeads();
      const idx = list.findIndex(x => x.id === id);
      if(idx === -1) return;
      list[idx].status = normalizeStatus(status, "NEW");
      if(list[idx].status === "CONTACTED" && !list[idx].followUp){
        list[idx].followUp = tomorrowYMD();
        list[idx].followUpDate = list[idx].followUp;
      }
      list[idx].updatedAt = new Date().toISOString();
      saveAllLeads(list);
      renderBuyerLeads();
      updateStats();
      toast("Buyer lead updated");
    }

    function setSellerStatus(id, status){
      const list = getSellerLeads();
      const idx = list.findIndex(x => x.id === id);
      if(idx === -1) return;
      list[idx].status = normalizeStatus(status, "NEW");
      saveSellerLeads(list);
      renderSellerLeads();
      updateStats();
      toast("Seller lead updated");
    }

    function setMaterialStatus(id, status){
      const list = getMaterialLeads();
      const idx = list.findIndex(x => x.id === id);
      if(idx === -1) return;
      list[idx].status = normalizeStatus(status, "NEW");
      saveMaterialLeads(list);
      renderMaterialLeads();
      updateStats();
      toast("Material lead updated");
    }

    function setServiceStatus(id, status){
      const list = getServiceLeads();
      const idx = list.findIndex(x => x.id === id);
      if(idx === -1) return;
      list[idx].status = normalizeStatus(status, "NEW");
      saveServiceLeads(list);
      renderServiceLeads();
      updateStats();
      toast("Service lead updated");
    }

    function openLeadModal(id){
      const lead = getAllLeads().find(x => x.id === id);
      if(!lead) return;
      MODAL_LEAD_ID = id;
      syncBrokerDropdowns();
      $("mLeadMeta").textContent = `${lead.listingTitle} • ${lead.buyerName} • ${lead.buyerPhone}`;
      $("mFollowUp").value = lead.followUp || "";
      $("mAssigned").value = lead.assignedTo || "";
      $("mStatus").value = lead.status || "NEW";
      $("mNotes").value = lead.notes || "";
      $("leadModalBack").hidden = false;
    }

    function closeLeadModal(){
      MODAL_LEAD_ID = null;
      $("leadModalBack").hidden = true;
    }

    function saveLeadModal(){
      if(!MODAL_LEAD_ID) return;
      const list = getAllLeads();
      const idx = list.findIndex(x => x.id === MODAL_LEAD_ID);
      if(idx === -1) return;

      list[idx].followUp = $("mFollowUp").value || "";
      list[idx].followUpDate = list[idx].followUp;
      list[idx].assignedTo = $("mAssigned").value || "";
      list[idx].assignedBrokerName = list[idx].assignedTo;
      list[idx].status = $("mStatus").value || "NEW";
      list[idx].notes = $("mNotes").value.trim();
      list[idx].updatedAt = new Date().toISOString();

      saveAllLeads(list);
      closeLeadModal();
      renderBuyerLeads();
      toast("Buyer lead saved");
    }

    function formatWA(phone){
      const p = normalizePhone(phone || "");
      return p.length === 10 ? "91" + p : p;
    }

    function exportCSV(filename, rows, mapper){
      if(!rows.length){
        alert("Export செய்ய data இல்லை");
        return;
      }

      const lines = rows.map(mapper);
      const headers = Object.keys(lines[0]);
      const csv = [
        headers.join(","),
        ...lines.map(obj => headers.map(h => `"${String(obj[h] ?? "").replace(/"/g,'""')}"`).join(","))
      ].join("\n");

      const blob = new Blob([csv], {type:"text/csv;charset=utf-8;"});
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      toast(`CSV exported: ${filename}`);
    }

    function bindTabs(){
      document.querySelectorAll(".tabBtn").forEach(btn => {
        btn.addEventListener("click", () => {
          const tab = btn.getAttribute("data-tab");
          document.querySelectorAll(".tabBtn").forEach(x => x.classList.remove("active"));
          document.querySelectorAll(".tabPanel").forEach(x => x.classList.remove("active"));
          btn.classList.add("active");
          $("panel-" + tab).classList.add("active");
        });
      });
    }

    function refreshAll(){
      $("waTemplate").value = getWATemplate();
      updatePreview();
      syncBrokerDropdowns();
      renderProperties();
      renderBuyerLeads();
      renderSellerLeads();
      renderMaterialLeads();
      renderServiceLeads();
      updateStats();
    }

    function resetDemoAction(){
      const typed = prompt("RESET என்று type பண்ணுங்கள்");
      if(String(typed || "").trim().toUpperCase() !== "RESET"){
        toast("Reset cancelled", "warn");
        return;
      }
      clearAllMeiData();
      seedData();
      refreshAll();
      toast("Demo data reset", "warn");
    }

    function bindEvents(){
      document.addEventListener("click", async (e) => {
        const actionBtn = e.target.closest("[data-action]");
        if(actionBtn){
          const act = actionBtn.getAttribute("data-action");
          if(act === "refreshAll") refreshAll();
          if(act === "resetDemo") resetDemoAction();
          if(act === "addBroker") addBrokerFromInput();
          if(act === "seedBrokers") seedDemoBrokers();
          if(act === "saveWATemplate") saveWATemplateAction();
          if(act === "resetWATemplate") resetWATemplateAction();
          if(act === "updatePreview") updatePreview();
          if(act === "copyPreview") copyPreviewAction();
          if(act === "closeLeadModal") closeLeadModal();
          if(act === "saveLeadModal") saveLeadModal();

          if(act === "exportBuyerCSV"){
            exportCSV("MEI_Buyer_Leads.csv", BUYER_EXPORT_CACHE, x => ({
              createdAt: fmtDate(x.createdAt),
              listingTitle: x.listingTitle,
              listingId: x.listingId,
              buyerName: x.buyerName,
              buyerPhone: x.buyerPhone,
              assignedTo: x.assignedTo,
              status: x.status,
              followUp: x.followUp,
              notes: x.notes,
              message: x.message
            }));
          }

          if(act === "exportSellerCSV"){
            exportCSV("MEI_Seller_Leads.csv", SELLER_EXPORT_CACHE, x => ({
              createdAt: fmtDate(x.createdAt),
              sellerName: x.sellerName,
              phone: x.phone,
              sellerType: x.sellerType,
              propertyType: x.propertyType,
              listingTitle: x.listingTitle,
              city: x.city,
              area: x.area,
              expectedPrice: x.expectedPrice,
              urgency: x.urgency,
              documentsReady: x.documentsReady,
              status: x.status,
              notes: x.notes
            }));
          }

          if(act === "exportMaterialCSV"){
            exportCSV("MEI_Material_Leads.csv", MATERIAL_EXPORT_CACHE, x => ({
              createdAt: fmtDate(x.createdAt),
              name: x.name,
              phone: x.phone,
              materialType: x.materialType,
              quantity: x.quantity,
              unit: x.unit,
              location: x.location,
              budget: x.budget,
              customerType: x.customerType,
              status: x.status,
              notes: x.notes
            }));
          }

          if(act === "exportServiceCSV"){
            exportCSV("MEI_Service_Leads.csv", SERVICE_EXPORT_CACHE, x => ({
              createdAt: fmtDate(x.createdAt),
              name: x.name,
              phone: x.phone,
              serviceType: x.serviceType,
              propertyType: x.propertyType,
              location: x.location,
              budget: x.budget,
              customerType: x.customerType,
              preferredDate: x.preferredDate,
              priority: x.priority,
              status: x.status,
              notes: x.notes
            }));
          }
        }

        const approveBtn = e.target.closest("[data-approve]");
        if(approveBtn) approveProp(approveBtn.getAttribute("data-approve"));

        const rejectBtn = e.target.closest("[data-reject]");
        if(rejectBtn) rejectProp(rejectBtn.getAttribute("data-reject"));

        const archiveBtn = e.target.closest("[data-archive]");
        if(archiveBtn) archiveProp(archiveBtn.getAttribute("data-archive"));

        const deleteBtn = e.target.closest("[data-delete]");
        if(deleteBtn) deleteProp(deleteBtn.getAttribute("data-delete"));

        const editBuyerBtn = e.target.closest("[data-edit-buyer]");
        if(editBuyerBtn) openLeadModal(editBuyerBtn.getAttribute("data-edit-buyer"));

        const waBuyerBtn = e.target.closest("[data-wa-buyer]");
        if(waBuyerBtn){
          const id = waBuyerBtn.getAttribute("data-wa-buyer");
          const lead = getAllLeads().find(x => x.id === id);
          if(lead && lead.buyerPhone){
            const msg = buildBuyerMessage(lead);
            window.open(`https://wa.me/${formatWA(lead.buyerPhone)}?text=${encodeURIComponent(msg)}`, "_blank");
            setBuyerStatus(id, "CONTACTED");
          }
        }

        const buyerStatusBtn = e.target.closest("[data-status-buyer]");
        if(buyerStatusBtn){
          setBuyerStatus(buyerStatusBtn.getAttribute("data-status-buyer"), buyerStatusBtn.getAttribute("data-next"));
        }

        const sellerStatusBtn = e.target.closest("[data-status-seller]");
        if(sellerStatusBtn){
          setSellerStatus(sellerStatusBtn.getAttribute("data-status-seller"), sellerStatusBtn.getAttribute("data-next"));
        }

        const matStatusBtn = e.target.closest("[data-status-material]");
        if(matStatusBtn){
          setMaterialStatus(matStatusBtn.getAttribute("data-status-material"), matStatusBtn.getAttribute("data-next"));
        }

        const serStatusBtn = e.target.closest("[data-status-service]");
        if(serStatusBtn){
          setServiceStatus(serStatusBtn.getAttribute("data-status-service"), serStatusBtn.getAttribute("data-next"));
        }
      });

      document.addEventListener("change", (e) => {
        if(e.target.matches("[data-assign-buyer]")){
          setBuyerAssigned(e.target.getAttribute("data-assign-buyer"), e.target.value);
        }
      });

      ["buyerSearch","buyerBrokerFilter","buyerStatusFilter","buyerOverdueFilter"].forEach(id => $(id).addEventListener("input", renderBuyerLeads));
      ["buyerBrokerFilter","buyerStatusFilter","buyerOverdueFilter"].forEach(id => $(id).addEventListener("change", renderBuyerLeads));

      ["sellerSearch","sellerStatusFilter","sellerTypeFilter","sellerPropertyTypeFilter"].forEach(id => $(id).addEventListener("input", renderSellerLeads));
      ["sellerStatusFilter","sellerTypeFilter","sellerPropertyTypeFilter"].forEach(id => $(id).addEventListener("change", renderSellerLeads));

      ["materialSearch","materialStatusFilter","materialTypeFilter","materialCustomerFilter"].forEach(id => $(id).addEventListener("input", renderMaterialLeads));
      ["materialStatusFilter","materialTypeFilter","materialCustomerFilter"].forEach(id => $(id).addEventListener("change", renderMaterialLeads));

      ["serviceSearch","serviceStatusFilter","serviceTypeFilter","serviceCustomerFilter"].forEach(id => $(id).addEventListener("input", renderServiceLeads));
      ["serviceStatusFilter","serviceTypeFilter","serviceCustomerFilter"].forEach(id => $(id).addEventListener("change", renderServiceLeads));

      $("waTemplate").addEventListener("input", updatePreview);

      document.querySelectorAll("[data-insert]").forEach(btn => {
        btn.addEventListener("click", () => {
          const ta = $("waTemplate");
          const insert = btn.getAttribute("data-insert");
          const start = ta.selectionStart ?? ta.value.length;
          const end = ta.selectionEnd ?? ta.value.length;
          ta.value = ta.value.slice(0,start) + insert + ta.value.slice(end);
          ta.focus();
          ta.setSelectionRange(start + insert.length, start + insert.length);
          updatePreview();
        });
      });

      $("brokerName").addEventListener("keydown", (e) => {
        if(e.key === "Enter"){
          e.preventDefault();
          addBrokerFromInput();
        }
      });

      $("leadModalBack").addEventListener("mousedown", (e) => {
        if(e.target === $("leadModalBack")) closeLeadModal();
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      seedData();
      bindTabs();
      bindEvents();
      refreshAll();
    });
  </script>
</body>
</html>
